t: 0;\n            background: white;\n            border: 1px solid #e8e8e8;\n            border-radius: 8px;\n            box-shadow: 0 4px 16px rgba(0,0,0,0.12);\n            z-index: 100;\n            margin-top: 4px;\n            max-height: 240px;\n            overflow-y: auto;\n        }\n\n        .search-dropdown.show { display: block; }\n\n        .search-result {\n            padding: 8px 12px;\n            cursor: pointer;\n            font-size: 13px;\n            border-bottom: 1px solid #f5f5f5;\n        }\n        .search-result:last-child { border-bottom: none; }\n        .search-result:hover { background: #f8f9ff; color: #667eea; }\n        .search-result .sub { font-size: 11px; color: #aaa; margin-top: 1px; }\n\n        /* ── Season select ── */\n        select {\n            padding: 8px 10px;\n            border: 2px solid #e8e8e8;\n            border-radius: 8px;\n            font-size: 13px;\n            outline: none;\n            color: #333;\n            background: white;\n        }\n        select:focus { border-color: #667eea; }\n\n        /* ── Player card (selected player) ── */\n        .player-card {\n            background: white;\n            border-radius: 12px;\n            box-shadow: 0 8px 24px rgba(0,0,0,0.18);\n            padding: 20px 24px;\n            display: none;\n        }\n        .player-card.show { display: block; }\n\n        .player-card h2 { font-size: 1.4em; color: #333; margin-bottom: 4px; }\n        .player-card .meta { color: #888; font-size: 0.88em; margin-bottom: 14px; }\n\n        .stat-row {\n            display: flex;\n            gap: 10px;\n            flex-wrap: wrap;\n        }\n\n        .stat-pill {\n            background: #f8f9ff;\n            border-radius: 8px;\n            padding: 6px 12px;\n            font-size: 12px;\n        }\n        .stat-pill span { font-weight: 700; color: #667eea; }\n\n        /* ── Segments ── */\n        .segments {\n            display: grid;\n            grid-template-columns: repeat(3, 1fr);\n            gap: 14px;\n        }\n\n        @media (max-width: 900px) {\n            .segments { grid-template-columns: 1fr; }\n        }\n\n        .segment-panel {\n            background: white;\n            border-radius: 12px;\n            box-shadow: 0 8px 24px rgba(0,0,0,0.18);\n            overflow: hidden;\n        }\n\n        .segment-header {\n            padding: 12px 16px;\n            font-weight: 700;\n            font-size: 0.88em;\n            text-transform: uppercase;\n            letter-spacing: 0.5px;\n            color: white;\n        }\n\n        .seg-production .segment-header { background: linear-gradient(135deg, #667eea, #764ba2); }\n        .seg-position   .segment-header { background: linear-gradient(135deg, #10b981, #059669); }\n        .seg-age        .segment-header { background: linear-gradient(135deg, #f59e0b, #d97706); }\n\n        .segment-header .sub {\n            font-size: 10px;\n            font-weight: 400;\n            opacity: 0.85;\n            text-transform: none;\n            letter-spacing: 0;\n            margin-top: 2px;\n        }\n\n        .sim-row {\n            display: flex;\n            align-items: center;\n            padding: 9px 14px;\n            border-bottom: 1px solid #f4f4f4;\n            gap: 10px;\n            cursor: default;\n        }\n        .sim-row:last-child { border-bottom: none; }\n        .sim-row:hover { background: #fafbff; }\n\n        .sim-rank {\n            font-size: 11px;\n            color: #ccc;\n            width: 16px;\n            flex-shrink: 0;\n            text-align: center;\n        }\n\n        .sim-info { flex: 1; min-width: 0; }\n\n        .sim-name {\n            font-weight: 600;\n            font-size: 13px;\n            color: #333;\n            white-space: nowrap;\n            overflow: hidden;\n            text-overflow: ellipsis;\n        }\n\n        .sim-meta {\n            font-size: 11px;\n            color: #aaa;\n            margin-top: 1px;\n            white-space: nowrap;\n            overflow: hidden;\n            text-overflow: ellipsis;\n        }\n\n        .sim-rating {\n            font-size: 12px;\n            font-weight: 700;\n            color: #10b981;\n            flex-shrink: 0;\n        }\n\n        .sim-score {\n            font-size: 10px;\n            color: #ccc;\n            flex-shrink: 0;\n            width: 36px;\n            text-align: right;\n        }\n\n        .empty-state {\n            padding: 30px;\n            text-align: center;\n            color: #bbb;\n            font-size: 13px;\n        }\n\n        .loading-state {\n            padding: 30px;\n            text-align: center;\n            color: #aaa;\n            font-size: 13px;\n        }\n    </style>\n</head>\n<body>\n<div class=\"page\">\n\n    <!-- Topbar -->\n    <div class=\"topbar\">\n        <h1>Similar <span>Players</span></h1>\n\n        <div class=\"search-wrap\">\n            <input type=\"text\" id=\"searchInput\" placeholder=\"Search player...\" autocomplete=\"off\">\n            <div class=\"search-dropdown\" id=\"searchDropdown\"></div>\n        </div>\n\n        <select id=\"seasonSelect\">\n            <option value=\"2025-26\">2025-26</option>\n        </select>\n\n        <a href=\"/\" class=\"nav-link\">← Player Rankings</a>\n    </div>\n\n    <!-- Selected player card -->\n    <div class=\"player-card\" id=\"playerCard\">\n        <h2 id=\"cardName\"></h2>\n        <div class=\"meta\" id=\"cardMeta\"></div>\n        <div class=\"stat-row\" id=\"cardStats\"></div>\n    </div>\n\n    <!-- Similarity panels -->\n    <div class=\"segments\" id=\"segments\">\n        <div class=\"segment-panel seg-production\">\n            <div class=\"segment-header\">\n                Production\n                <div class=\"sub\">All positions · all seasons</div>\n            </div>\n            <div id=\"list-production\"><div class=\"empty-state\">Search for a player above</div></div>\n        </div>\n        <div class=\"segment-panel seg-position\">\n            <div class=\"segment-header\">\n                Same Position\n                <div class=\"sub\">Same position group · all seasons</div>\n            </div>\n            <div id=\"list-position\"><div class=\"empty-state\">Search for a player above</div></div>\n        </div>\n        <div class=\"segment-panel seg-age\">\n            <div class=\"segment-header\">\n                Same Age\n                <div class=\"sub\">±1 year or same class · all seasons</div>\n            </div>\n            <div id=\"list-age\"><div class=\"empty-state\">Search for a player above</div></div>\n        </div>\n    </div>\n\n</div>\n\n<script>\nconst API_BASE = (location.port === '3000' || location.port === '5500' || location.port === '5173')\n    ? 'http://localhost:8000/api'\n    : '/api';\n\nlet searchTimeout = null;\nlet selectedPlayer = null;\n\nconst searchInput   = document.getElementById('searchInput');\nconst searchDropdown = document.getElementById('searchDropdown');\nconst seasonSelect  = document.getElementById('seasonSelect');\n\n// ── Search ────────────────────────────────────────────────────────────────\nsearchInput.addEventListener('input', () => {\n    clearTimeout(searchTimeout);\n    const q = searchInput.value.trim();\n    if (q.length < 2) { searchDropdown.classList.remove('show'); return; }\n    searchTimeout = setTimeout(() => doSearch(q), 200);\n});\n\nsearchInput.addEventListener('blur', () => {\n    setTimeout(() => searchDropdown.classList.remove('show'), 150);\n});\n\nasync function doSearch(q) {\n    const res = await fetch(`${API_BASE}/players/search?q=${encodeURIComponent(q)}&limit=8`);\n    const data = await res.json();\n    renderDropdown(data.results);\n}\n\nfunction renderDropdown(results) {\n    searchDropdown.innerHTML = '';\n    if (!results.length) {\n        searchDropdown.innerHTML = '<div class=\"search-result\" style=\"color:#aaa\">No results</div>';\n    } else {\n        results.forEach(r => {\n            const div = document.createElement('div');\n            div.className = 'search-result';\n            div.innerHTML = `<div>${r.full_name}</div>`;\n            div.addEventListener('click', () => selectPlayer(r));\n            searchDropdown.appendChild(div);\n        });\n    }\n    searchDropdown.classList.add('show');\n}\n\nasync function selectPlayer(r) {\n    selectedPlayer = r;\n    searchInput.value = r.full_name;\n    searchDropdown.classList.remove('show');\n    await loadSimilarity(r.player_id, seasonSelect.value);\n}\n\nseasonSelect.addEventListener('change', () => {\n    if (selectedPlayer) loadSimilarity(selectedPlayer.player_id, seasonSelect.value);\n});\n\n// ── Similarity ────────────────────────────────────────────────────────────\nasync function loadSimilarity(playerId, season) {\n    ['production', 'position', 'age'].forEach(seg => {\n        document.getElementById(`list-${seg}`).innerHTML =\n            '<div class=\"loading-state\">Loading...</div>';\n    });\n\n    const [simRes, playerRes] = await Promise.all([\n        fetch(`${API_BASE}/similarity/${playerId}/${season}`),\n        fetch(`${API_BASE}/players/${season}?limit=15000`)\n    ]);\n\n    const simData   = await simRes.json();\n    const playerData = await playerRes.json();\n    const player = playerData.data.find(p => p.player_id == playerId);\n\n    renderPlayerCard(player);\n\n    ['production', 'position', 'age'].forEach(seg => {\n        const rows = simData.segments?.[seg] || [];\n        renderSegment(seg, rows);\n    });\n}\n\nfunction renderPlayerCard(p) {\n    if (!p) return;\n    const card = document.getElementById('playerCard');\n    card.classList.add('show');\n\n    document.getElementById('cardName').textContent = p.full_name;\n    document.getElementById('cardMeta').textContent =\n        [p.team, p.position, p.class_year, p.height, p.weight ? p.weight + ' lbs' : null, p.age ? 'Age ' + p.age : null]\n        .filter(Boolean).join(' · ');\n\n    const stats = [\n        ['Rating', p.final_rating?.toFixed(1)],\n        ['PPG', p.pts?.toFixed(1)],\n        ['RPG', p.reb?.toFixed(1)],\n        ['APG', p.ast?.toFixed(1)],\n        ['SPG', p.stl?.toFixed(1)],\n        ['BPG', p.blk?.toFixed(1)],\n        ['MIN', p.min?.toFixed(1)],\n        ['3PA', p.fg3a?.toFixed(1)],\n        ['3P%', p.fg3_pct != null ? (p.fg3_pct * 100).toFixed(1) + '%' : null],\n        ['FG%', p.fg_pct != null ? (p.fg_pct * 100).toFixed(1) + '%' : null],\n        ['USG%', p.usg_pct != null ? Number(p.usg_pct).toFixed(1) + '%' : null],\n        ['TS%', p.ts_pct != null ? (p.ts_pct * 100).toFixed(1) + '%' : null],\n    ];\n\n    document.getElementById('cardStats').innerHTML = stats\n        .filter(([, v]) => v != null)\n        .map(([l, v]) => `<div class=\"stat-pill\">${l} <span>${v}</span></div>`)\n        .join('');\n}\n\nfunction renderSegment(seg, rows) {\n    const el = document.getElementById(`list-${seg}`);\n    if (!rows.length) {\n        el.innerHTML = '<div class=\"empty-state\">No similar players found</div>';\n        return;\n    }\n    el.innerHTML = rows.map(r => `\n        <div class=\"sim-row\">\n            <div class=\"sim-rank\">${r.rank}</div>\n            <div class=\"sim-info\">\n                <div class=\"sim-name\">${r.sim_name}</div>\n                <div class=\"sim-meta\">${r.sim_team} · ${r.sim_pos} · ${r.sim_season}</div>\n            </div>\n            <div class=\"sim-rating\">${Number(r.sim_rating).toFixed(1)}</div>\n            <div class=\"sim-score\">${Number(r.score).toFixed(3)}</div>\n        </div>\n    `).join('');\n}\n</script>\n</body>\n</html>\n",
