lue=\"2023-24\">2023-24</option>\n381\t                <option value=\"2022-23\">2022-23</option>\n382\t                <option value=\"2021-22\">2021-22</option>\n383\t            </select>\n384\t        </div>\n385\t\n386\t        <div class=\"sidebar-field\">\n387\t            <label>Search</label>\n388\t            <input type=\"text\" id=\"searchBox\" placeholder=\"Player name...\">\n389\t        </div>\n390\t\n391\t        <!-- Sliders injected here -->\n392\t        <div id=\"sliderContainer\"></div>\n393\t\n394\t        <!-- Position chips -->\n395\t        <div class=\"slider-group-label\">Position</div>\n396\t        <div class=\"pos-group\" id=\"posChips\"></div>\n397\t\n398\t        <button class=\"btn-reset\" onclick=\"resetFilters()\">Reset all filters</button>\n399\t    </aside>\n400\t\n401\t    <!-- ── Main ── -->\n402\t    <div class=\"main\">\n403\t        <div class=\"main-topbar\">\n404\t            <h1>Player Stats &amp; Ratings</h1>\n405\t            <span class=\"results-count\" id=\"resultsCount\"></span>\n406\t        </div>\n407\t\n408\t        <div id=\"loading\" class=\"loading\">Loading data...</div>\n409\t\n410\t        <div class=\"table-container\" id=\"tableContainer\" style=\"display:none\">\n411\t            <table>\n412\t                <thead>\n413\t                    <tr>\n414\t                        <th style=\"cursor:default\">#</th>\n415\t                        <th data-col=\"full_name\" style=\"min-width:145px\">Player</th>\n416\t                        <th data-col=\"team\" style=\"min-width:115px\">Team</th>\n417\t                        <th data-col=\"position\">Pos</th>\n418\t                        <th data-col=\"class_year\">Yr</th>\n419\t                        <th data-col=\"gp\">GP</th>\n420\t                        <th data-col=\"min\">MIN</th>\n421\t                        <th data-col=\"pts\">PPG</th>\n422\t                        <th data-col=\"reb\">RPG</th>\n423\t                        <th data-col=\"ast\">APG</th>\n424\t                        <th data-col=\"stl\">SPG</th>\n425\t                        <th data-col=\"blk\">BPG</th>\n426\t                        <th data-col=\"tov\">TOV</th>\n427\t                        <th data-col=\"fg_pct\">FG%</th>\n428\t                        <th data-col=\"fg3_pct\">3P%</th>\n429\t                        <th data-col=\"ft_pct\">FT%</th>\n430\t                        <th data-col=\"ts_pct\">TS%</th>\n431\t                        <th data-col=\"per\">PER</th>\n432\t                        <th data-col=\"usg_pct\">USG%</th>\n433\t                        <th data-col=\"ws\">WS</th>\n434\t                        <th data-col=\"final_rating\" class=\"sort-desc\">Rating</th>\n435\t                    </tr>\n436\t                </thead>\n437\t                <tbody id=\"tableBody\"></tbody>\n438\t            </table>\n439\t        </div>\n440\t    </div>\n441\t</div>\n442\t\n443\t<!-- Modal -->\n444\t<div id=\"playerModal\" class=\"modal\">\n445\t    <div class=\"modal-content\">\n446\t        <button class=\"close-btn\" onclick=\"closeModal()\">&times;</button>\n447\t        <div id=\"playerDetails\"></div>\n448\t    </div>\n449\t</div>\n450\t\n451\t<script>\n452\tconst API_BASE = '/api';\n453\t\n454\tconst STAT_DEFS = [\n455\t    { key: 'final_rating', label: 'Rating',      group: 'RATING',      pct: false, decimals: 1 },\n456\t    { key: 'pts',          label: 'PPG',          group: 'SCORING',     pct: false, decimals: 1 },\n457\t    { key: 'min',          label: 'MIN',          group: 'SCORING',     pct: false, decimals: 1 },\n458\t    { key: 'fg_pct',       label: 'FG%',          group: 'SCORING',     pct: true,  decimals: 1 },\n459\t    { key: 'fg3_pct',      label: '3P%',          group: 'SCORING',     pct: true,  decimals: 1 },\n460\t    { key: 'ft_pct',       label: 'FT%',          group: 'SCORING',     pct: true,  decimals: 1 },\n461\t    { key: 'ast',          label: 'APG',          group: 'PLAYMAKING',  pct: false, decimals: 1 },\n462\t    { key: 'tov',          label: 'TOV',          group: 'PLAYMAKING',  pct: false, decimals: 1 },\n463\t    { key: 'reb',          label: 'RPG',          group: 'REBOUNDING',  pct: false, decimals: 1 },\n464\t    { key: 'stl',          label: 'SPG',          group: 'DEFENSE',     pct: false, decimals: 1 },\n465\t    { key: 'blk',          label: 'BPG',          group: 'DEFENSE',     pct: false, decimals: 1 },\n466\t    { key: 'ts_pct',       label: 'TS%',          group: 'EFFICIENCY',  pct: true,  decimals: 1 },\n467\t    { key: 'per',          label: 'PER',          group: 'EFFICIENCY',  pct: false, decimals: 1 },\n468\t    { key: 'usg_pct',      label: 'USG%',         group: 'EFFICIENCY',  pct: false, decimals: 1 },\n469\t    { key: 'ws',           label: 'Win Shares',   group: 'EFFICIENCY',  pct: false, decimals: 2 },\n470\t];\n471\t\n472\tconst sliderState = {};\n473\tlet allPlayers = [];\n474\tlet currentSeason = '2025-26';\n475\tlet sortCol = 'final_rating';\n476\tlet sortDir = -1;\n477\tlet activePositions = new Set();\n478\t\n479\t// ── Boot ──────────────────────────────────────────────────────────────────\n480\tdocument.addEventListener('DOMContentLoaded', () => {\n481\t    document.getElementById('seasonSelect').addEventListener('change', e => {\n482\t        currentSeason = e.target.value;\n483\t        loadPlayers();\n484\t    });\n485\t    document.getElementById('searchBox').addEventListener('input', applyFilters);\n486\t\n487\t    document.querySelectorAll('th[data-col]').forEach(th => {\n488\t        th.addEventListener('click', () => {\n489\t            const col = th.dataset.col;\n490\t            sortDir = sortCol === col ? sortDir * -1 : -1;\n491\t            sortCol = col;\n492\t            document.querySelectorAll('th').forEach(t => t.classList.remove('sort-asc','sort-desc'));\n493\t            th.classList.add(sortDir === -1 ? 'sort-desc' : 'sort-asc');\n494\t            applyFilters();\n495\t        });\n496\t    });\n497\t\n498\t    loadPlayers();\n499\t});\n500\t\n501\t// ── Data load ─────────────────────────────────────────────────────────────\n502\tasync function loadPlayers() {\n503\t    document.getElementById('loading').style.display = 'block';\n504\t    document.getElementById('tableContainer').style.display = 'none';\n505\t\n506\t    try {\n507\t        const res = await fetch(`${API_BASE}/players/${currentSeason}?limit=15000`);\n508\t        const data = await res.json();\n509\t        allPlayers = data.data;\n510\t\n511\t        buildSliders();\n512\t        buildPositionChips();\n513\t        applyFilters();\n514\t\n515\t        document.getElementById('loading').style.display = 'none';\n516\t        document.getElementById('tableContainer').style.display = 'block';\n517\t    } catch (err) {\n518\t        document.getElementById('loading').textContent = 'Error loading data — is the API running?';\n519\t        console.error(err);\n520\t    }\n521\t}\n522\t\n523\t// ── Sliders ───────────────────────────────────────────────────────────────\n524\tfunction buildSliders() {\n525\t    const container = document.getElementById('sliderContainer');\n526\t    container.innerHTML = '';\n527\t    let lastGroup = null;\n528\t\n529\t    STAT_DEFS.forEach(def => {\n530\t        const vals = allPlayers\n531\t            .map(p => p[def.key] != null ? (def.pct ? Number(p[def.key]) * 100 : Number(p[def.key])) : null)\n532\t            .filter(v => v != null);\n533\t\n534\t        if (!vals.length) return;\n535\t\n536\t        const dataMin = Math.floor(Math.min(...vals) * 10) / 10;\n537\t        const dataMax = Math.ceil(Math.max(...vals) * 10) / 10;\n538\t        sliderState[def.key] = { dataMin, dataMax, curMin: dataMin, curMax: dataMax };\n539\t\n540\t        const fmtBound = v => def.pct ? v.toFixed(0) + '%' : v.toFixed(def.decimals);\n541\t\n542\t        const row = document.createElement('div');\n543\t        row.className = 'slider-row';\n544\t        row.innerHTML = `\n545\t            <div class=\"slider-top\">\n546\t                <span class=\"slider-label\">${def.label}</span>\n547\t                <span class=\"slider-current\" id=\"${def.key}-current\">any</span>\n548\t            </div>\n549\t            <div class=\"range-wrap\">\n550\t                <div class=\"range-track\">\n551\t                    <div class=\"range-fill\" id=\"${def.key}-fill\"></div>\n552\t                </div>\n553\t                <input type=\"range\" id=\"${def.key}-min\" min=\"${dataMin}\" max=\"${dataMax}\" value=\"${dataMin}\" step=\"any\">\n554\t                <input type=\"range\" id=\"${def.key}-max\" min=\"${dataMin}\" max=\"${dataMax}\" value=\"${dataMax}\" step=\"any\">\n555\t            </div>\n556\t            <div class=\"range-bounds\">\n557\t                <span>${fmtBound(dataMin)}</span>\n558\t                <span>${fmtBound(dataMax)}</span>\n559\t            </div>\n560\t        `;\n561\t        container.appendChild(row);\n562\t\n563\t        document.getElementById(`${def.key}-min`).addEventListener('input', () => onSlider(def, 'min'));\n564\t        document.getElementById(`${def.key}-max`).addEventListener('input', () => onSlider(def, 'max'));\n565\t    });\n566\t}\n567\t\n568\tfunction onSlider(def, handle) {\n569\t    const minEl = document.getElementById(`${def.key}-min`);\n570\t    const maxEl = document.getElementById(`${def.key}-max`);\n571\t    let minVal = parseFloat(minEl.value);\n572\t    let maxVal = parseFloat(maxEl.value);\n573\t\n574\t    if (handle === 'min' && minVal > maxVal) { minEl.value = maxVal; minVal = maxVal; }\n575\t    if (handle === 'max' && maxVal < minVal) { maxEl.value = minVal; maxVal = minVal; }\n576\t\n577\t    sliderState[def.key].curMin = minVal;\n578\t    sliderState[def.key].curMax = maxVal;\n579\t\n580\t    updateSliderUI(def);\n581\t    applyFilters();\n582\t}\n583\t\n584\tfunction updateSliderUI(def) {\n585\t    const s = sliderState[def.key];\n586\t    if (!s) return;\n587\t\n588\t    const { dataMin, dataMax, curMin, curMax } = s;\n589\t    const span = dataMax - dataMin || 1;\n590\t    const leftPct  = (curMin - dataMin) / span * 100;\n591\t    const rightPct = (curMax - dataMin) / span * 100;\n592\t\n593\t    document.getElementById(`${def.key}-fill`).style.cssText =\n594\t        `left:${leftPct}%; width:${rightPct - leftPct}%`;\n595\t\n596\t    const fmtV = v => def.pct ? v.toFixed(def.decimals) + '%' : v.toFixed(def.decimals);\n597\t    document.getElementById(`${def.key}-current`).textContent =\n598\t        (curMin === dataMin && curMax === dataMax) ? 'any' : `${fmtV(curMin)} – ${fmtV(curMax)}`;\n599\t}\n600\t\n601\t// ── Position chips ────────────────────────────────────────────────────────\n602\tfunction buildPositionChips() {\n603\t    const positions = [...new Set(allPlayers.map(p => p.position).filter(Boolean))].sort();\n604\t    const container = document.getElementById('posChips');\n605\t    container.innerHTML = '';\n606\t    activePositions.clear();\n607\t\n608\t    positions.forEach(pos => {\n609\t        const chip = document.createElement('div');\n610\t        chip.className = 'pos-chip';\n611\t        chip.textContent = pos;\n612\t        chip.addEventListener('click', () => {\n613\t            if (activePositions.has(pos)) { activePositions.delete(pos); chip.classList.remove('active'); }\n614\t            else                          { activePositions.add(pos);    chip.classList.add('active'); }\n615\t            applyFilters();\n616\t        });\n617\t        container.appendChild(chip);\n618\t    });\n619\t}\n620\t\n621\t// ── Filter + render ───────────────────────────────────────────────────────\n622\tfunction applyFilters() {\n623\t    const search = document.getElementById('searchBox').value.toLowerCase().trim();\n624\t\n625\t    let filtered = allPlayers.filter(p => {\n626\t        if (search && !p.full_name.toLowerCase().includes(search)) return false;\n627\t        if (activePositions.size > 0 && !activePositions.has(p.position)) return false;\n628\t\n629\t        for (const def of STAT_DEFS) {\n630\t            const s = sliderState[def.key];\n631\t            if (!s || (s.curMin === s.dataMin && s.curMax === s.dataMax)) continue;\n632\t            const raw = p[def.key];\n633\t            if (raw == null) return false;\n634\t            const v = def.pct ? Number(raw) * 100 : Number(raw);\n635\t            if (v < s.curMin || v > s.curMax) return false;\n636\t        }\n637\t\n638\t        return true;\n639\t    });\n640\t\n641\t    filtered.sort((a, b) => {\n642\t        const av = a[sortCol], bv = b[sortCol];\n643\t        if (av == null && bv == null) return 0;\n644\t        if (av == null) return 1;\n645\t        if (bv == null) return -1;\n646\t        return typeof av === 'string' ? av.localeCompare(bv) * sortDir : (av - bv) * sortDir;\n647\t    });\n648\t\n649\t    document.getElementById('resultsCount').textContent =\n650\t        `${filtered.length.toLocaleString()} player${filtered.length !== 1 ? 's' : ''}`;\n651\t    renderTable(filtered);\n652\t}\n653\t\n654\tfunction fmt(v, d = 1)  { return v != null ? Number(v).toFixed(d) : '-'; }\n655\tfunction fmtP(v, d = 1) { return v != null ? (Number(v) * 100).toFixed(d) + '%' : '-'; }\n656\t\n657\tfunction renderTable(players) {\n658\t    const tbody = document.getElementById('tableBody');\n659\t    tbody.innerHTML = '';\n660\t    const MAX = 500;\n661\t\n662\t    players.slice(0, MAX).forEach((p, i) => {\n663\t        const tr = document.createElement('tr');\n664\t        tr.addEventListener('click', () => showModal(p.player_id));\n665\t        tr.innerHTML = `\n666\t            <td style=\"color:#ccc;font-size:.88em\">${i + 1}</td>\n667\t            <td><span class=\"player-name\">${p.full_name}</span></td>\n668\t            <td>${p.team || '-'}</td>\n669\t            <td>${p.position || '-'}</td>\n670\t            <td style=\"color:#aaa\">${p.class_year || '-'}</td>\n671\t            <td>${p.gp ?? '-'}</td>\n672\t            <td>${fmt(p.min)}</td>\n673\t            <td>${fmt(p.pts)}</td>\n674\t            <td>${fmt(p.reb)}</td>\n675\t            <td>${fmt(p.ast)}</td>\n676\t            <td>${fmt(p.stl)}</td>\n677\t            <td>${fmt(p.blk)}</td>\n678\t            <td>${fmt(p.tov)}</td>\n679\t            <td>${fmtP(p.fg_pct)}</td>\n680\t            <td>${fmtP(p.fg3_pct)}</td>\n681\t            <td>${fmtP(p.ft_pct)}</td>\n682\t            <td>${fmtP(p.ts_pct)}</td>\n683\t            <td>${fmt(p.per)}</td>\n684\t            <td>${p.usg_pct != null ? Number(p.usg_pct).toFixed(1) : '-'}</td>\n685\t            <td>${fmt(p.ws, 2)}</td>\n686\t            <td class=\"rating-cell\">${fmt(p.final_rating)}</td>\n687\t        `;\n688\t        tbody.appendChild(tr);\n689\t    });\n690\t\n691\t    if (players.length > MAX) {\n692\t        const tr = document.createElement('tr');\n693\t        tr.className = 'more-row';\n694\t        tr.innerHTML = `<td colspan=\"21\">Showing ${MAX} of ${players.length.toLocaleString()} — use filters to narrow results</td>`;\n695\t        tbody.appendChild(tr);\n696\t    }\n697\t}\n698\t\n699\t// ── Reset ─────────────────────────────────────────────────────────────────\n700\tfunction resetFilters() {\n701\t    STAT_DEFS.forEach(def => {\n702\t        const s = sliderState[def.key];\n703\t        if (!s) return;\n704\t        s.curMin = s.dataMin;\n705\t        s.curMax = s.dataMax;\n706\t        const minEl = document.getElementById(`${def.key}-min`);\n707\t        const maxEl = document.getElementById(`${def.key}-max`);\n708\t        if (minEl) minEl.value = s.dataMin;\n709\t        if (maxEl) maxEl.value = s.dataMax;\n710\t        updateSliderUI(def);\n711\t    });\n712\t    activePositions.clear();\n713\t    document.querySelectorAll('.pos-chip').forEach(c => c.classList.remove('active'));\n714\t    document.getElementById('searchBox').value = '';\n715\t    applyFilters();\n716\t}\n717\t\n718\t// ── Modal ─────────────────────────────────────────────────────────────────\n719\tfunction showModal(playerId) {\n720\t    const p = allPlayers.find(x => x.player_id == playerId);\n721\t    if (!p) return;\n722\t    document.getElementById('playerModal').classList.add('show');\n723\t\n724\t    document.getElementById('playerDetails').innerHTML = `\n725\t        <div class=\"player-header\">\n726\t            <h2>${p.full_name}</h2>\n727\t            <div class=\"meta\">\n728\t                ${p.team || '-'} &nbsp;|&nbsp; ${p.position || '-'} &nbsp;|&nbsp;\n729\t                ${p.class_year || '-'} &nbsp;|&nbsp;\n730\t                ${p.height || '-'} &nbsp;|&nbsp; ${p.weight ? p.weight + ' lbs' : '-'}\n731\t                ${p.hometown ? ' &nbsp;|&nbsp; ' + p.hometown : ''}\n732\t            </div>\n733\t            <a class=\"realgm-link\" href=\"https://basketball.realgm.com/player/x/Summary/${p.player_id}\" target=\"_blank\">View on RealGM</a>\n734\t        </div>\n735\t\n736\t        <div class=\"player-overview\">\n737\t            ${iBox('Rating', `<span style=\"color:#10b981;font-size:1.35em\">${fmt(p.final_rating)}</span>`)}\n738\t            ${iBox('Two-Way', p.two_way === 'Y' ? 'Yes' : 'No')}\n739\t            ${iBox('GP', p.gp ?? '-')}\n740\t            ${iBox('MIN/G', fmt(p.min))}\n741\t            ${iBox('PER', fmt(p.per))}\n742\t            ${iBox('TS%', fmtP(p.ts_pct))}\n743\t            ${iBox('Win Shares', fmt(p.ws, 2))}\n744\t            ${iBox('USG%', p.usg_pct != null ? Number(p.usg_pct).toFixed(1) + '%' : '-')}\n745\t        </div>\n746\t\n747\t        <div class=\"stats-section\">\n748\t            <h3>Per-Game Stats</h3>\n749\t            <div class=\"stats-grid\">\n750\t                ${sBox('Points', fmt(p.pts))}\n751\t                ${sBox('Rebounds', fmt(p.reb))}\n752\t                ${sBox('Assists', fmt(p.ast))}\n753\t                ${sBox('Steals', fmt(p.stl))}\n754\t                ${sBox('Blocks', fmt(p.blk))}\n755\t                ${sBox('Turnovers', fmt(p.tov))}\n756\t                