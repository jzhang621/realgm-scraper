     \"endpoints\": {\n61\t            \"ratings\": \"/api/ratings/{season}\",\n62\t            \"player\": \"/api/player/{player_id}\",\n63\t            \"stats\": \"/api/stats/{player_id}/{season}\",\n64\t            \"compare\": \"/api/compare\",\n65\t            \"search\": \"/api/search\",\n66\t            \"teams\": \"/api/teams/{season}\"\n67\t        }\n68\t    }\n69\t\n70\t@app.get(\"/api/ratings/{season}\")\n71\tdef get_ratings(\n72\t    season: str,\n73\t    position: Optional[str] = None,\n74\t    team: Optional[str] = None,\n75\t    min_rating: Optional[float] = None,\n76\t    two_way: Optional[str] = None,\n77\t    limit: int = Query(100, le=15000),\n78\t    offset: int = 0\n79\t):\n80\t    \"\"\"\n81\t    Get player ratings for a season with optional filters\n82\t\n83\t    - **season**: \"2024-25\" or \"2025-26\"\n84\t    - **position**: Filter by position\n85\t    - **team**: Filter by team\n86\t    - **min_rating**: Minimum rating threshold\n87\t    - **two_way**: \"Y\" for two-way players only\n88\t    - **limit**: Max results (default 100, max 500)\n89\t    - **offset**: Pagination offset\n90\t    \"\"\"\n91\t    with engine.connect() as conn:\n92\t        query = \"\"\"\n93\t            SELECT *\n94\t            FROM player_ratings\n95\t            WHERE season = :season\n96\t        \"\"\"\n97\t        params = {'season': season}\n98\t\n99\t        if position:\n100\t            query += \" AND position = :position\"\n101\t            params['position'] = position\n102\t\n103\t        if team:\n104\t            query += \" AND team = :team\"\n105\t            params['team'] = team\n106\t\n107\t        if min_rating:\n108\t            query += \" AND final_rating >= :min_rating\"\n109\t            params['min_rating'] = min_rating\n110\t\n111\t        if two_way == 'Y':\n112\t            query += \" AND two_way = 'Y'\"\n113\t\n114\t        query += \" ORDER BY final_rating DESC LIMIT :limit OFFSET :offset\"\n115\t        params['limit'] = limit\n