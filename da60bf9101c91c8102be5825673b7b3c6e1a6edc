68\t                    <option value=\"\">All Teams</option>\n269\t                </select>\n270\t\n271\t                <label>Min Rating:</label>\n272\t                <input type=\"number\" id=\"minRating\" placeholder=\"0\" min=\"0\" max=\"100\" style=\"width: 80px\">\n273\t\n274\t                <label>Search:</label>\n275\t                <input type=\"text\" id=\"searchBox\" placeholder=\"Player name...\" style=\"width: 200px\">\n276\t            </div>\n277\t        </div>\n278\t\n279\t        <div id=\"loading\" class=\"loading\">Loading data...</div>\n280\t\n281\t        <div class=\"table-container\" id=\"tableContainer\" style=\"display: none;\">\n282\t            <table>\n283\t                <thead>\n284\t                    <tr>\n285\t                        <th>Rank</th>\n286\t                        <th>Player</th>\n287\t                        <th>Team</th>\n288\t                        <th>Pos</th>\n289\t                        <th>GP</th>\n290\t                        <th>PPG</th>\n291\t                        <th>RPG</th>\n292\t                        <th>APG</th>\n293\t                        <th>Rating</th>\n294\t                    </tr>\n295\t                </thead>\n296\t                <tbody id=\"tableBody\">\n297\t                </tbody>\n298\t            </table>\n299\t        </div>\n300\t    </div>\n301\t\n302\t    <!-- Player Detail Modal -->\n303\t    <div id=\"playerModal\" class=\"modal\">\n304\t        <div class=\"modal-content\">\n305\t            <button class=\"close-btn\" onclick=\"closePlayerModal()\">&times;</button>\n306\t            <div id=\"playerDetails\">\n307\t                <div class=\"loading\">Loading player details...</div>\n308\t            </div>\n309\t        </div>\n310\t    </div>\n311\t\n312\t    <script>\n313\t        const API_BASE = 'http://localhost:8000/api';\n314\t        let allPlayers = [];\n315\t        let currentSeason = '2025-26';\n316\t\n317\t        // Load data on page load\n318\t        document.addEventListener('DOMContentLoaded', () => {\n319\t            loadPlayers();\n320\t\n321\t            // Add event listeners\n322\t            document.getElementById('seasonSelect').addEventListener('change', (e) => {\n323\t                currentSeason = e.target.value;\n324\t                loadPlayers();\n325\t            });\n326\t\n327\t            document.getElementById('positionFilter').addEventListener('change', filterPlayers);\n328\t            document.getElementById('teamFilter').addEventListener('change', filterPlayers);\n329\t            document.getElementById('minRating').addEventListener('input', filterPlayers);\n330\t            document.getElementById('searchBox').addEventListener('input', filterPlayers);\n331\t        });\n332\t\n333\t        async function loadPlayers() {\n334\t            try {\n335\t                document.getElementById('loading').style.display = 'block';\n336\t                document.getElementById('tableContainer').style.display = 'none';\n337\t\n338\t                const response = await fetch(`${API_BASE}/ratings/${currentSeason}?limit=15000`);\n339\t                const data = await response.json();\n340\t\n341\t                allPlayers = data.data;\n342\t\n343\t                // Populate filters\n344\t                const positions = [...new Set(allPlayers.map(p => p.position).filter(Boolean))].sort();\n345\t                const teams = [...new Set(allPlayers.map(p => p.team).filter(Boolean))].sort();\n346\t\n347\t                const posSelect = document.getElementById('positionFilter');\n348\t                posSelect.innerHTML = '<option value=\"\">All Positions</option>';\n349\t                positions.forEach(pos => {\n350\t                    posSelect.innerHTML += `<option value=\"${pos}\">${pos}</option>`;\n351\t                });\n352\t\n353\t                const teamSelect = document.getElementById('teamFilter');\n354\t                teamSelect.innerHTML = '<option value=\"\">All Teams</option>';\n355\t                teams.forEach(team => {\n356\t                    teamSelect.innerHTML += `<option value=\"${team}\">${team}</option>`;\n357\t                });\n358\t\n359\t                filterPlayers();\n360\t\n361\t                document.getElementById('loading').style.display = 'none';\n362\t                document.getElementById('tableContainer').style.display = 'block';\n363\t\n364\t            } catch (error) {\n365\t                console.error('Error loading data:', error);\n366\t                document.getElementById('loading').textContent = 'Error loading data. Check console.';\n367\t            }\n368\t        }\n369\t\n370\t        function filterPlayers() {\n371\t            const position = document.getElementById('positionFilter').value;\n372\t            const team = document.getElementById('teamFilter').value;\n373\t            const minRating = parseFloat(document.getElementById('minRating').value) || 0;\n374\t            const search = document.getElementById('searchBox').value.toLowerCase();\n375\t\n376\t            let filtered = allPlayers.filter(player => {\n377\t                if (position && player.position !== position) return false;\n378\t                if (team && player.team !== team) return false;\n379\t                if (player.final_rating < minRating) return false;\n380\t                if (search && !player.full_name.toLowerCase().includes(search)) return false;\n381\t                return true;\n382\t            });\n383\t\n384\t            displayPlayers(filtered);\n385\t        }\n386\t\n387\t        function displayPlayers(players) {\n388\t            const tbody = document.getElementById('tableBody');\n389\t            tbody.innerHTML = '';\n390\t\n391\t            players.slice(0, 100).forEach((player, index) => {\n392\t                const row = document.createElement('tr');\n393\t                row.innerHTML = `\n394\t                    <td>${index + 1}</td>\n395\t                    <td>\n396\t                        <span class=\"player-name\" onclick=\"showPlayerDetail('${player.player_id}')\">\n397\t                            ${player.full_name}\n398\t                        </span>\n399\t                        ${player.two_way === 'Y' ? '<span class=\"two-way-badge\">2-WAY</span>' : ''}\n400\t                    </td>\n401\t                    <td>${player.team || '-'}</td>\n402\t                    <td>${player.position || '-'}</td>\n403\t                    <td>${player.gp || '-'}</td>\n404\t                    <td>${player.pts?.toFixed(1) || '-'}</td>\n405\t                    <td>${player.reb?.toFixed(1) || '-'}</td>\n406\t                    <td>${player.ast?.toFixed(1) || '-'}</td>\n407\t                    <td class=\"rating-cell\">${player.final_rating?.toFixed(1) || '-'}</td>\n408\t                `;\n409\t                tbody.appendChild(row);\n410\t            });\n411\t        }\n412\t\n413\t        async function showPlayerDetail(playerId) {\n414\t            const modal = document.getElementById('playerModal');\n415\t            const details = document.getElementById('playerDetails');\n416\t\n417\t            modal.classList.add('show');\n418\t            details.innerHTML = '<div class=\"loading\">Loading player details...</div>';\n419\t\n420\t            try {\n421\t                // Fetch player stats\n422\t                const statsResponse = await fetch(`${API_BASE}/stats/${playerId}/${currentSeason}`);\n423\t                const statsData = await statsResponse.json();\n424\t\n425\t                const player = statsData.rating || {};\n426\t                const pergame = statsData.pergame || {};\n427\t                const advanced = statsData.advanced || {};\n428\t                const misc = statsData.misc || {};\n429\t\n430\t                details.innerHTML = `\n431\t                    <div class=\"player-header\">\n432\t                        <h2>${player.full_name || 'Unknown Player'}</h2>\n433\t             