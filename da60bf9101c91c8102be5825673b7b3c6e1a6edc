t\n59\t    def _rate_limit(self):\n60\t        \"\"\"Sleep between requests. Burst pause every N requests.\"\"\"\n61\t        self._request_count += 1\n62\t        if self._request_count % config.BURST_EVERY == 0:\n63\t            pause = random.uniform(config.BURST_SLEEP_MIN, config.BURST_SLEEP_MAX)\n64\t            logger.info(f\"Burst pause: sleeping {pause:.1f}s after {self._request_count} requests\")\n65\t            time.sleep(pause)\n66\t        else:\n67\t            time.sleep(random.uniform(config.SLEEP_MIN, config.SLEEP_MAX))\n68\t\n69\t    def get(self, url: str, use_cache: bool = True) -> str:\n70\t        \"\"\"\n71\t        Fetch a URL and return HTML string.\n72\t        - Checks local cache first (skip request if cached)\n73\t        - Retries with exponential backoff on transient errors\n74\t        - Raises on permanent failure (403 after retry, 404)\n75\t        \"\"\"\n76\t        cache_path = self._cache_path(url)\n77\t\n78\t        # Return from cache if available\n79\t        if use_cache and os.path.exists(cache_path):\n80\t            logger.debug(f\"Cache hit: {url}\")\n81\t            with open(cache_path, \"r\", encoding=\"utf-8\") as f:\n82\t                return f.read()\n83\t\n84\t        # Rate limit before making request\n85\t        self._rate_limit()\n86\t\n87\t        sleep = config.RETRY_BASE_SLEEP\n88\t        last_error = None\n89\t\n90\t        for attempt in range(1, config.MAX_RETRIES + 1):\n91\t            try:\n92\t                logger.info(f\"GET {url} (attempt {attempt})\")\n93\t                resp = self._scraper.get(url, timeout=30)\n94\t\n95\t                if resp.status_code == 200:\n96\t                    html = resp.text\n97\t                    # Save to cache\n98\t                    with open(cache_path, \"w\", encoding=\"utf-8\") as f:\n99\t                        f.write(html)\n100\t                    return html\n101\t\n102\t                elif resp.status_code == 404:\n103\t                    raise FileNotFoundError(f\"404 Not Found: {url}\")\n104\t\n105\t                elif resp.status_code == 403:\n106\t                    logger.warning(f\"403 Forbidden: {url} — refreshing scraper session\")\n107\t                    self._scraper = self._new_scraper()\n108\t                    if attempt == config.MAX_RETRIES:\n109\t                        raise PermissionError(f\"403 Forbidden after {attempt} attempts: {url}\")\n110\t\n111\t                elif resp.status_code in (429, 500, 502, 503, 504):\n112\t                    logger.warning(f\"HTTP {resp.status_code}: {url} — backing off {sleep}s\")\n113\t\n114\t                else:\n115\t                    raise RuntimeError(f\"Unexpected HTTP {resp.status_code}: {url}\")\n116\t\n117\t            except (cloudscraper.exceptions.CloudflareChallengeError,\n118\t                    cloudscraper.exceptions.CloudflareIUAMError) as e:\n119\t                logger.warning(f\"Cloudflare challenge on {url}: {e} — backing off {sleep}s\")\n120\t                last_error = e\n121\t\n122\t            except Exception as e:\n123\t                # Catch requests.ConnectionError, Timeout, etc.\n124\t                cls = type(e).__name__\n125\t                if cls in (\"ConnectionError\", \"Timeout\", \"ReadTimeout\"):\n126\t                    logger.warning(f\"Network error on {url}: {e} — backing off {sleep}s\")\n127\t                    last_error = e\n128\t                else:\n129\t                    raise  # re-raise unexpected errors immediately\n130\t\n131\t            # Exponential backoff before retry\n132\t            if attempt < config.MAX_RETRIES:\n133\t                time.sleep(sleep)\n134\t                sleep *= 2\n135\t\n136\t        raise RuntimeError(f\"Failed to fetch {url} after {config.MAX_RETRIES} attempts. Last error: {last_error}\")\n137\t\n138\t\n139\t# Module-level singleton\n140\t_fetcher = None\n141\t\n142\t\n143\tdef get(url: str, use_cache: bool = True) -> str:\n144\t    global _fetch