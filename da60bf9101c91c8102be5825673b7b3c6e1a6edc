oup players by hometown coords\n    const groups = {};\n    pagePlayers.forEach(p => {\n        if (!p.hometown) return;\n        const c = mapCoords[p.hometown];\n        if (!c) return;\n        const key = `${c.lat},${c.lng}`;\n        if (!groups[key]) groups[key] = { lat: c.lat, lng: c.lng, players: [] };\n        groups[key].players.push(p);\n    });\n\n    Object.values(groups).forEach(({ lat, lng, players }) => {\n        const marker = L.circleMarker([lat, lng], {\n            radius: Math.min(4 + players.length * 2, 14),\n            fillColor: '#667eea',\n            color: '#fff',\n            weight: 1.5,\n            fillOpacity: 0.85,\n        });\n\n        const popupHtml = players.map(p =>\n            `<div style=\"margin-bottom:4px\">\n                <strong style=\"color:#667eea;cursor:pointer\" onclick=\"showModal('${p.player_id}')\">${p.full_name}</strong>\n                <span style=\"color:#aaa;font-size:11px\"> · ${p.team} · ${fmt(p.final_rating)}</span>\n            </div>`\n        ).join('');\n\n        marker.bindPopup(`\n            <div style=\"font-size:12px;min-width:180px\">\n                <div style=\"font-weight:700;color:#333;margin-bottom:6px\">${players[0].hometown}</div>\n                ${popupHtml}\n            </div>\n        `, { maxWidth: 280 });\n\n        mapMarkers.addLayer(marker);\n    });\n\n    // Fit bounds if markers exist\n    if (mapMarkers.getLayers().length > 0) {\n        const bounds = mapMarkers.getBounds();\n        if (bounds.isValid()) map.fitBounds(bounds, { padding: [40, 40] });\n    }\n}",
