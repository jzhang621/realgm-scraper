| '-'}</div>\n466\t                            </div>\n467\t                            <div class=\"stat-box\">\n468\t                                <div class=\"stat-label\">Rebounds</div>\n469\t                                <div class=\"stat-value\">${pergame.trb?.toFixed(1) || '-'}</div>\n470\t                            </div>\n471\t                            <div class=\"stat-box\">\n472\t                                <div class=\"stat-label\">Assists</div>\n473\t                                <div class=\"stat-value\">${pergame.ast?.toFixed(1) || '-'}</div>\n474\t                            </div>\n475\t                            <div class=\"stat-box\">\n476\t                                <div class=\"stat-label\">Steals</div>\n477\t                                <div class=\"stat-value\">${pergame.stl?.toFixed(1) || '-'}</div>\n478\t                            </div>\n479\t                            <div class=\"stat-box\">\n480\t                                <div class=\"stat-label\">Blocks</div>\n481\t                                <div class=\"stat-value\">${pergame.blk?.toFixed(1) || '-'}</div>\n482\t                            </div>\n483\t                            <div class=\"stat-box\">\n484\t                                <div class=\"stat-label\">FG%</div>\n485\t                                <div class=\"stat-value\">${pergame.fg_pct ? (pergame.fg_pct * 100).toFixed(1) + '%' : '-'}</div>\n486\t                            </div>\n487\t                            <div class=\"stat-box\">\n488\t                                <div class=\"stat-label\">3P%</div>\n489\t                                <div class=\"stat-value\">${pergame.fg3_pct ? (pergame.fg3_pct * 100).toFixed(1) + '%' : '-'}</div>\n490\t                            </div>\n491\t                            <div class=\"stat-box\">\n492\t                                <div class=\"stat-label\">FT%</div>\n493\t                                <div class=\"stat-value\">${pergame.ft_pct ? (pergame.ft_pct * 100).toFixed(1) + '%' : '-'}</div>\n494\t                            </div>\n495\t                        </div>\n496\t                    </div>\n497\t\n498\t                    <div class=\"stats-section\">\n499\t                        <h3>Advanced Stats</h3>\n500\t                        <div class=\"stats-grid\">\n501\t                            <div class=\"stat-box\">\n502\t                                <div class=\"stat-label\">PER</div>\n503\t                                <div class=\"stat-value\">${advanced.per?.toFixed(1) || '-'}</div>\n504\t                            </div>\n505\t                            <div class=\"stat-box\">\n506\t                                <div class=\"stat-label\">TS%</div>\n507\t                                <div class=\"stat-value\">${advanced.ts_pct ? (advanced.ts_pct * 100).toFixed(1) + '%' : '-'}</div>\n508\t                            </div>\n509\t                            <div class=\"stat-box\">\n510\t                                <div class=\"stat-label\">Usage%</div>\n511\t                                <div class=\"stat-value\">${advanced.usg_pct?.toFixed(1) || '-'}</div>\n512\t                            </div>\n513\t                            <div class=\"stat-box\">\n514\t                                <div class=\"stat-label\">ORtg</div>\n515\t                                <div class=\"stat-value\">${advanced.ortg?.toFixed(1) || '-'}</div>\n516\t                            </div>\n517\t                        </div>\n518\t                    </div>\n519\t\n520\t                    <div class=\"stats-section\">\n521\t                        <h3>Misc Stats</h3>\n522\t                        <div class=\"stats-grid\">\n523\t                            <div class=\"stat-box\">\n524\t                                <div class=\"stat-label\">Double-Doubles</div>\n525\t                                <div class=\"stat-value\">${misc.dbl_dbl || '-'}</div>\n526\t                            </div>\n527\t                            <div class=\"stat-box\">\n528\t                                <div class=\"stat-label\">Triple-Doubles</div>\n529\t                                <div class=\"stat-value\">${misc.tpl_dbl || '-'}</div>\n530\t                            </div>\n531\t                            <div class=\"stat-box\">\n532\t                                <div class=\"stat-label\">Win Shares</div>\n533\t                                <div class=\"stat-value\">${misc.ws?.toFixed(2) || '-'}</div>\n534\t                            </div>\n535\t                        </div>\n536\t                    </div>\n537\t                `;\n538\t\n539\t            } catch (error) {\n540\t                console.error('Error loading player details:', error);\n541\t                details.innerHTML = '<div class=\"loading\">Error loading player details.</div>';\n542\t            }\n543\t        }\n544\t\n545\t        function closePlayerModal() {\n546\t            document.getElementById('playerModal').classList.remove('show');\n547\t        }\n548\t\n549\t        // Close modal on outside click\n550\t        window.onclick = function(event) {\n551\t            const modal = document.getElementById('playerModal');\n552\t            if (event.target === modal) {\n553\t                closePlayerModal();\n554\t            }\n555\t        }\n556\t    </script>\n557\t</body>\n558\t</html>\n559\t",
