  label: '3P%',          group: 'SCORING',     pct: true,  decimals: 1 },\n567\t    { key: 'ft_pct',       label: 'FT%',          group: 'SCORING',     pct: true,  decimals: 1 },\n568\t    { key: 'ast',          label: 'APG',          group: 'PLAYMAKING',  pct: false, decimals: 1 },\n569\t    { key: 'tov',          label: 'TOV',          group: 'PLAYMAKING',  pct: false, decimals: 1 },\n570\t    { key: 'reb',          label: 'RPG',          group: 'REBOUNDING',  pct: false, decimals: 1 },\n571\t    { key: 'stl',          label: 'SPG',          group: 'DEFENSE',     pct: false, decimals: 1 },\n572\t    { key: 'blk',          label: 'BPG',          group: 'DEFENSE',     pct: false, decimals: 1 },\n573\t    { key: 'ts_pct',       label: 'TS%',          group: 'EFFICIENCY',  pct: true,  decimals: 1 },\n574\t    { key: 'per',          label: 'PER',          group: 'EFFICIENCY',  pct: false, decimals: 1 },\n575\t    { key: 'usg_pct',      label: 'USG%',         group: 'EFFICIENCY',  pct: false, decimals: 1 },\n576\t    { key: 'ws',           label: 'Win Shares',   group: 'EFFICIENCY',  pct: false, decimals: 2 },\n577\t];\n578\t\n579\tconst sliderState = {};\n580\tlet allPlayers = [];\n581\tlet currentSeason = '2025-26';\n582\tlet sortCol = 'final_rating';\n583\tlet sortDir = -1;\n584\tlet activePositions = new Set();\n585\tlet currentPage = 1;\n586\tconst PAGE_SIZE = 100;\n587\tlet filteredPlayers = [];\n588\t\n589\t// ── Boot ──────────────────────────────────────────────────────────────────\n590\tdocument.addEventListener('DOMContentLoaded', () => {\n591\t    document.getElementById('seasonSelect').addEventListener('change', e => {\n592\t        currentSeason = e.target.value;\n593\t        currentPage = 1;\n594\t        loadPlayers();\n595\t    });\n596\t    document.getElementById('searchBox').addEventListener('input', applyFilters);\n597\t\n598\t    document.querySelectorAll('th[data-col]').forEach(th => {\n599\t        th.addEventListener('click', () => {\n600\t            const col = th.dataset.col;\n601\t            sortDir = sortCol === col ? sortDir * -1 : -1;\n602\t            sortCol = col;\n603\t            document.querySelectorAll('th').forEach(t => t.classList.remove('sort-asc','sort-desc'));\n604\t            th.classList.add(sortDir === -1 ? 'sort-desc' : 'sort-asc');\n605\t            applyFilters();\n606\t        });\n607\t    });\n608\t\n609\t    loadPlayers();\n610\t});\n611\t\n612\t// ── Data load ─────────────────────────────────────────────────────────────\n613\tasync function loadPlayers() {\n614\t    document.getElementById('loading').style.display = 'block';\n615\t    document.getElementById('tableContainer').style.display = 'none';\n616\t\n617\t    try {\n618\t        const res = await fetch(`${API_BASE}/players/${currentSeason}?limit=15000`);\n619\t        const data = await res.json();\n620\t        allPlayers = data.data;\n621\t\n622\t        buildSliders();\n623\t        buildPositionChips();\n624\t        applyFilters();\n625\t\n626\t        document.getElementById('loading').style.display = 'none';\n627\t        document.getElementById('tableContainer').style.display = 'block';\n628\t    } catch (err) {\n629\t        document.getElementById('loading').textContent = 'Error loading data — is the API running?';\n630\t        console.error(err);\n631\t    }\n632\t}\n633\t\n634\t// ── Sliders ───────────────────────────────────────────────────────────────\n635\tfunction buildSliders() {\n636\t    const container = document.getElementById('sliderContainer');\n637\t    container.innerHTML = '';\n638\t    let lastGroup = null;\n639\t\n640\t    STAT_DEFS.forEach(def => {\n641\t        const vals = allPlayers\n642\t            .map(p => p[def.key] != null ? (def.pct ? Number(p[def.key]) * 100 : Number(p[def.key])) : null)\n643\t            .filter(v => v != null);\n644\t\n645\t        if (!vals.length) return;\n646\t\n647\t        const dataMin = Math.floor(Math.min(...vals) * 10) / 10;\n648\t        const dataMax = Math.ceil(Math.max(...vals) * 10) / 10;\n649\t        sliderState[def.key] = { dataMin, dataMax, curMin: dataMin, curMax: dataMax };\n650\t\n651\t        const fmtBound = v => def.pct ? v.toFixed(0) + '%' : v.toFixed(def.decimals);\n652\t\n653\t        const row = document.createElement('div');\n654\t        row.className = 'slider-row';\n655\t        row.innerHTML = `\n656\t            <div class=\"slider-top\">\n657\t                <span class=\"slider-label\">${def.label}</span>\n658\t                <span class=\"slider-current\" id=\"${def.key}-current\">any</span>\n659\t            </div>\n660\t            <div class=\"range-wrap\">\n661\t                <div class=\"range-track\">\n662\t                    <div class=\"range-fill\" id=\"${def.key}-fill\"></div>\n663\t                </div>\n664\t                <input type=\"range\" id=\"${def.key}-min\" min=\"${dataMin}\" max=\"${dataMax}\" value=\"${dataMin}\" step=\"any\">\n665\t                <input type=\"range\" id=\"${def.key}-max\" min=\"${dataMin}\" max=\"${dataMax}\" value=\"${dataMax}\" step=\"any\">\n666\t            </div>\n667\t            <div class=\"range-bounds\">\n668\t                <span>${fmtBound(dataMin)}</span>\n669\t                <span>${fmtBound(dataMax)}</span>\n670\t            </div>\n671\t        `;\n672\t        container.appendChild(row);\n673\t\n674\t        document.getElementById(`${def.key}-min`).addEventListener('input', () => onSlider(def, 'min'));\n675\t        document.getElementById(`${def.key}-max`).addEventListener('input', () => onSlider(def, 'max'));\n676\t    });\n677\t}\n678\t\n679\tfunction onSlider(def, handle) {\n680\t    const minEl = document.getElementById(`${def.key}-min`);\n681\t    const maxEl = document.getElementById(`${def.key}-max`);\n682\t    let minVal = parseFloat(minEl.value);\n683\t    let maxVal = parseFloat(maxEl.value);\n684\t\n685\t    if (handle === 'min' && minVal > maxVal) { minEl.value = maxVal; minVal = maxVal; }\n686\t    if (handle === 'max' && maxVal < minVal) { maxEl.value = minVal; maxVal = minVal; }\n687\t\n688\t    sliderState[def.key].curMin = minVal;\n689\t    sliderState[def.key].curMax = maxVal;\n690\t\n691\t    updateSliderUI(def);\n692\t    applyFilters();\n693\t}\n694\t\n695\tfunction updateSliderUI(def) {\n696\t    const s = sliderState[def.key];\n697\t    if (!s) return;\n698\t\n699\t    const { dataMin, dataMax, curMin, curMax } = s;\n700\t    const span = dataMax - dataMin || 1;\n701\t    const leftPct  = (curMin - dataMin) / span * 100;\n702\t    const rightPct = (curMax - dataMin) / span * 100;\n703\t\n704\t    document.getElementById(`${def.key}-fill`).style.cssText =\n705\t        `left:${leftPct}%; width:${rightPct - leftPct}%`;\n706\t\n707\t    const fmtV = v => def.pct ? v.toFixed(def.decimals) + '%' : v.toFixed(def.decimals);\n708\t    document.getElementById(`${def.key}-current`).textContent =\n709\t        (curMin === dataMin && curMax === dataMax) ? 'any' : `${fmtV(curMin)} – ${fmtV(curMax)}`;\n710\t}\n711\t\n712\t// ── Position chips (pos_group) ────────────────────────────────────────────\n713\tfunction buildPositionChips() {\n714\t    const groups = ['Guard', 'Wing', 'Big'];\n715\t    const container = document.getElementById('posChips');\n716\t    container.innerHTML = '';\n717\t    activePositions.clear();\n718\t\n719\t    groups.forEach(pos => {\n720\t        const chip = document.createElement('div');\n721\t        chip.className = 'pos-chip';\n722\t        chip.textContent = pos;\n723\t        chip.addEventListener('click', () => {\n724\t            if (activePositions.has(pos)) { activePositions.delete(pos); chip.classList.remove('active'); }\n725\t            else                          { activePositions.add(pos);    chip.classList.add('active'); }\n726\t            applyFilters();\n727\t        });\n728\t        container.appendChild(chip);\n729\t    });\n730\t}\n731\t\n732\t\n733\t// ── Filter + render ───────────────────────────────────────────────────────\n734\tfunction applyFilters() {\n735\t    const search = document.getElementById('searchBox').value.toLowerCase().trim();\n736\t\n737\t    let filtered = allPlayers.filter(p => {\n738\t        if (search && !p.full_name.toLowerCase().includes(search)) return false;\n739\t        if (activePositions.size > 0 && !activePositions.has(p.pos_group)) return false;\n740\t\n741\t        for (const def of STAT_DEFS) {\n742\t            const s = sliderState[def.key];\n743\t            if (!s || (s.curMin === s.dataMin && s.curMax === s.dataMax)) continue;\n744\t            const raw = p[def.key];\n745\t            if (raw == null) return false;\n746\t            const v = def.pct ? Number(raw) * 100 : Number(raw);\n747\t            if (v < s.curMin || v > s.curMax) return false;\n748\t        }\n749\t\n750\t        return true;\n751\t    });\n752\t\n753\t    filtered.sort((a, b) => {\n754\t        const av = a[sortCol], bv = b[sortCol];\n755\t        if (av == null && bv == null) return 0;\n756\t        if (av == null) return 1;\n757\t        if (bv == null) return -1;\n758\t        return typeof av === 'string' ? av.localeCompare(bv) * sortDir : (av - bv) * sortDir;\n759\t    });\n760\t\n761\t    filteredPlayers = filtered;\n762\t    currentPage = 1;\n763\t    document.getElementById('resultsCount').textContent =\n764\t        `${filtered.length.toLocaleString()} player${filtered.length !== 1 ? 's' : ''}`;\n765\t    renderPage();\n766\t}\n767\t\n768\tfunction fmt(v, d = 1)  { return v != null ? Number(v).toFixed(d) : '-'; }\n769\tfunction fmtP(v, d = 1) { return v != null ? (Number(v) * 100).toFixed(d) + '%' : '-'; }\n770\t\n771\tfunction renderPage() {\n772\t    const totalPages = Math.ceil(filteredPlayers.length / PAGE_SIZE);\n773\t    const start = (currentPage - 1) * PAGE_SIZE;\n774\t    const pageRows = filteredPlayers.slice(start, start + PAGE_SIZE);\n775\t    renderTable(pageRows, start);\n776\t    renderPagination(totalPages);\n777\t    if (currentView === 'map') updateMapMarkers();\n778\t}\n779\t\n780\tfunction renderTable(players, offset = 0) {\n781\t    const tbody = document.getElementById('tableBody');\n782\t    tbody.innerHTML = '';\n783\t\n784\t    players.forEach((p, i) => {\n785\t        const tr = document.createElement('tr');\n786\t        tr.addEventListener('click', () => showModal(p.player_id));\n787\t        tr.innerHTML = `\n788\t            <td style=\"color:#ccc;font-size:.88em\">${offset + i + 1}</td>\n789\t            <td><span class=\"player-name\">${p.full_name}</span></td>\n790\t            <td>${p.team || '-'}</td>\n791\t            <td>${p.position || '-'}</td>\n792\t            <td style=\"color:#aaa\">${p.class_year || '-'}</td>\n793\t            <td>${p.gp ?? '-'}</td>\n794\t            <td>${fmt(p.min)}</td>\n795\t            <td>${fmt(p.pts)}</td>\n796\t            <td>${fmt(p.reb)}</td>\n797\t            <td>${fmt(p.ast)}</td>\n798\t            <td>${fmt(p.stl)}</td>\n799\t            <td>${fmt(p.blk)}</td>\n800\t            <td>${fmt(p.tov)}</td>\n801\t            <td>${fmtP(p.fg_pct)}</td>\n802\t            <td>${fmt(p.fg3m)}</td>\n803\t            <td>${fmt(p.fg3a)}</td>\n804\t            <td>${fmtP(p.fg3_pct)}</td>\n805\t            <td>${fmtP(p.ft_pct)}</td>\n806\t            <td>${fmtP(p.ts_pct)}</td>\n807\t            <td>${fmt(p.per)}</td>\n808\t            <td>${p.usg_pct != null ? Number(p.usg_pct).toFixed(1) : '-'}</td>\n809\t            <td>${fmt(p.ws, 2)}</td>\n810\t            <td class=\"rating-cell\">${fmt(p.final_rating)}</td>\n811\t        `;\n812\t        tbody.appendChild(tr);\n813\t    });\n814\t}\n815\t\n816\tfunction renderPagination(totalPages) {\n817\t    const el = document.getElementById('pagination');\n818\t    if (totalPages <= 1) { el.style.display = 'none'; return; }\n819\t    el.style.display = 'flex';\n820\t\n821\t    const start = (currentPage - 1) * PAGE_SIZE + 1;\n822\t    const end = Math.min(currentPage * PAGE_SIZE, filteredPlayers.length);\n823\t\n824\t    // Show up to 7 page buttons around current page\n825\t    const pages = [];\n826\t    for (let i = 1; i <= totalPages; i++) {\n827\t        if (i === 1 || i === totalPages || (i >= currentPage - 2 && i <= currentPage + 2)) {\n828\t            pages.push(i);\n829\t        }\n830\t    }\n831\t\n832\t    let html = `<button class=\"pg-btn\" ${currentPage === 1 ? 'disabled' : ''} onclick=\"goPage(${currentPage - 1})\">← Prev</button>`;\n833\t    let prev = null;\n834\t    pages.forEach(p => {\n835\t        if (prev && p - prev > 1) html += `<span class=\"pg-info\">…</span>`;\n836\t        html += `<button class=\"pg-btn ${p === currentPage ? 'active' : ''}\" onclick=\"goPage(${p})\">${p}</button>`;\n837\t        prev = p;\n838\t    });\n839\t    html += `<button class=\"pg-btn\" ${currentPage === totalPages ? 'disabled' : ''} onclick=\"goPage(${currentPage + 1})\">Next →</button>`;\n840\t    html += `<span class=\"pg-info\">${start}–${end} of ${filteredPlayers.length.toLocaleString()}</span>`;\n841\t\n842\t    el.innerHTML = html;\n843\t}\n844\t\n845\tfunction goPage(page) {\n846\t    currentPage = page;\n847\t    renderPage();\n848\t    document.getElementById('tableContainer').scrollIntoView({ behavior: 'smooth', block: 'start' });\n849\t}\n850\t\n851\t// ── Reset ─────────────────────────────────────────────────────────────────\n852\tfunction resetFilters() {\n853\t    STAT_DEFS.forEach(def => {\n854\t        const s = sliderState[def.key];\n855\t        if (!s) return;\n856\t        s.curMin = s.dataMin;\n857\t        s.curMax = s.dataMax;\n858\t        const minEl = document.getElementById(`${def.key}-min`);\n859\t        const maxEl = document.getElementById(`${def.key}-max`);\n860\t        if (minEl) minEl.value = s.dataMin;\n861\t        if (maxEl) maxEl.value = s.dataMax;\n862\t        updateSliderUI(def);\n863\t    });\n864\t    activePositions.clear();\n865\t    document.querySelectorAll('.pos-chip').forEach(c => c.classList.remove('active')