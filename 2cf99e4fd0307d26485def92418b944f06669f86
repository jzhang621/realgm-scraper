     updateSliderUI(def);\n    });\n}\n\nfunction onSliderInput(def, handle) {\n    const minEl = document.getElementById(`${def.key}-min`);\n    const maxEl = document.getElementById(`${def.key}-max`);\n    let minVal = parseFloat(minEl.value);\n    let maxVal = parseFloat(maxEl.value);\n\n    // Prevent crossing\n    if (handle === 'min' && minVal > maxVal) { minEl.value = maxVal; minVal = maxVal; }\n    if (handle === 'max' && maxVal < minVal) { maxEl.value = minVal; maxVal = minVal; }\n\n    sliderState[def.key].curMin = minVal;\n    sliderState[def.key].curMax = maxVal;\n\n    updateSliderUI(def);\n    applyFilters();\n}\n\nfunction updateSliderUI(def) {\n    const s = sliderState[def.key];\n    if (!s) return;\n\n    const { dataMin, dataMax, curMin, curMax } = s;\n    const span = dataMax - dataMin || 1;\n    const leftPct  = (curMin - dataMin) / span * 100;\n    const rightPct = (curMax - dataMin) / span * 100;\n\n    const fill = document.getElementById(`${def.key}-fill`);\n    fill.style.left  = leftPct + '%';\n    fill.style.width = (rightPct - leftPct) + '%';\n\n    const disp = document.getElementById(`${def.key}-display`);\n    const fmt = v => def.pct ? v.toFixed(def.decimals) + '%' : v.toFixed(def.decimals);\n    disp.textContent = (curMin === dataMin && curMax === dataMax)\n        ? 'any'\n        : `${fmt(curMin)} – ${fmt(curMax)}`;\n}\n\nfunction initPositionChips() {\n    const positions = [...new Set(allPlayers.map(p => p.position).filter(Boolean))].sort();\n    const container = document.getElementById('posChips');\n    container.innerHTML = '';\n    activePositions.clear();\n\n    positions.forEach(pos => {\n        const chip = document.createElement('label');\n        chip.className = 'pos-chip';\n        chip.innerHTML = `<input type=\"checkbox\" value=\"${pos}\"> ${pos}`;\n        chip.addEventListener('click', e => {\n            e.preventDefault(); // we handle manually\n            if (activePositions.has(pos)) {\n                activePositions.delete(pos);\n                chip.classList.remove('active');\n            } else {\n                activePositions.add(pos);\n                chip.classList.add('active');\n            }\n            applyFilters();\n        });\n        container.appendChild(chip);\n    });\n}\n\n// ── Data load ─────────────────────────────────────────────────────────────\nasync function loadPlayers() {\n    document.getElementById('loading').style.display = 'block';\n    document.getElementById('tableContainer').style.display = 'none';\n\n    try {\n        const res = await fetch(`${API_BASE}/players/${currentSeason}?limit=15000`);\n        const data = await res.json();\n        allPlayers = data.data;\n\n        initSliders();\n        initPositionChips();\n        applyFilters();\n\n        document.getElementById('loading').style.display = 'none';\n        document.getElementById('tableContainer').style.display = 'block';\n    } catch (err) {\n        document.getElementById('loading').textContent = 'Error loading data — is the API running?';\n        console.error(err);\n    }\n}\n\n// ── Filter + display ──────────────────────────────────────────────────────\nfunction applyFilters() {\n    const search = document.getElementById('searchBox').value.toLowerCase().trim();\n\n    let filtered = allPlayers.filter(p => {\n        // Name search\n        if (search && !p.full_name.toLowerCase().includes(search)) return false;\n\n        // Position chips\n        if (activePositions.size > 0 && !activePositions.has(p.position)) return false;\n\n        // Sliders\n        for (const def of STAT_DEFS) {\n            const s = sliderState[def.key];\n            if (!s) continue;\n            // Skip if at full range (no filter applied)\n            if (s.curMin === s.dataMin && s.curMax === s.dataMax) continue;\n\n            const raw = p[def.key];\n            if (raw == null) return false;\n            const v = def.pct ? Number(raw) * 100 : Number(raw);\n            if (v < s.curMin || v > s.curMax) return false;\n        }\n\n        return true;\n    });\n\n    // Sort\n    filtered.sort((a, b) => {\n        let av = a[sortCol], bv = b[sortCol];\n        if (av == null && bv == null) return 0;\n        if (av == null) return 1;\n        if (bv == null) return -1;\n        return (typeof av === 'string') ? av.localeCompare(bv) * sortDir : (av - bv) * sortDir;\n    });\n\n    document.getElementById('resultsCount').textContent = `${filtered.length.toLocaleString()} players`;\n    renderTable(filtered);\n}\n\nfunction fmt(v, d = 1)    { return v != null ? Number(v).toFixed(d) : '-'; }\nfunction fmtP(v, d = 1)   { return v != null ? (Number(v)*100).toFixed(d)+'%' : '-'; }\n\nfunction renderTable(players) {\n    const tbody = document.getElementById('tableBody');\n    tbody.innerHTML = '';\n    const MAX = 500;\n\n    players.slice(0, MAX).forEach((p, i) => {\n        const tr = document.createElement('tr');\n        tr.addEventListener('click', () => showModal(p.player_id));\n        tr.innerHTML = `\n            <td style=\"color:#bbb;font-size:.9em\">${i+1}</td>\n            <td><span class=\"player-name\">${p.full_name}</span>${p.two_way==='Y'?'<span class=\"two-way-badge\">2-WAY</span>':''}</td>\n            <td>${p.team||'-'}</td>\n            <td>${p.position||'-'}</td>\n            <td style=\"color:#999\">${p.class_year||'-'}</td>\n            <td>${p.gp??'-'}</td>\n            <td>${fmt(p.min)}</td>\n            <td>${fmt(p.pts)}</td>\n            <td>${fmt(p.reb)}</td>\n            <td>${fmt(p.ast)}</td>\n            <td>${fmt(p.stl)}</td>\n            <td>${fmt(p.blk)}</td>\n            <td>${fmt(p.tov)}</td>\n            <td>${fmtP(p.fg_pct)}</td>\n            <td>${fmtP(p.fg3_pct)}</td>\n            <td>${fmtP(p.ft_pct)}</td>\n            <td>${fmtP(p.ts_pct)}</td>\n            <td>${fmt(p.per)}</td>\n            <td>${p.usg_pct!=null?Number(p.usg_pct).toFixed(1):'−'}</td>\n            <td>${fmt(p.ws,2)}</td>\n            <td class=\"rating-cell\">${fmt(p.final_rating)}</td>\n        `;\n        tbody.appendChild(tr);\n    });\n\n    if (players.length > MAX) {\n        const tr = document.createElement('tr');\n        tr.className = 'more-row';\n        tr.innerHTML = `<td colspan=\"21\">Showing ${MAX} of ${players.length.toLocaleString()} — tighten filters to narrow results</td>`;\n        tbody.appendChild(tr);\n    }\n}\n\n// ── Controls ──────────────────────────────────────────────────────────────\nfunction toggleFilters() {\n    filterOpen = !filterOpen;\n    const panel = document.getElementById('filterPanel');\n    panel.classList.toggle('collapsed', !filterOpen);\n    panel.classList.toggle('expanded', filterOpen);\n    document.getElementById('filterToggle').textContent = filterOpen ? 'Filters ▴' : 'Filters ▾';\n}\n\nfunction resetFilters() {\n    STAT_DEFS.forEach(def => {\n        const s = sliderState[def.key];\n        if (!s) return;\n        s.curMin = s.dataMin;\n        s.curMax = s.dataMax;\n        document.getElementById(`${def.key}-min`).value = s.dataMin;\n        document.getElementById(`${def.key}-max`).value = s.dataMax;\n        updateSliderUI(def);\n    });\n\n    activePositions.clear();\n    document.querySelectorAll('.pos-chip').forEach(c => c.classList.remove('active'));\n    document.getElementById('searchBox').value = '';\n    applyFilters();\n}\n\n// ── Modal ─────────────────────────────────────────────────────────────────\nfunction showModal(playerId) {\n    const p = allPlayers.find(x => x.player_id == playerId);\n    if (!p) return;\n\n    document.getElementById('playerModal').classList.add('show');\n    const details = document.getElementById('playerDetails');\n\n    details.innerHTML = `\n        <div class=\"player-header\">\n            <h2>${p.full_name}</h2>\n            <div class=\"meta\">\n                ${p.team||'-'} &nbsp;|&nbsp; ${p.position||'-'} &nbsp;|&nbsp;\n                ${p.class_year||'-'} &nbsp;|&nbsp;\n                ${p.height||'-'} &nbsp;|&nbsp; ${p.weight?p.weight+' lbs':'-'}\n                ${p.hometown?' &nbsp;|&nbsp; '+p.hometown:''}\n            </div>\n            <a class=\"realgm-link\" href=\"https://basketball.realgm.com/player/x/Summary/${p.player_id}\" target=\"_blank\">View on RealGM</a>\n        </div>\n\n        <div class=\"player-overview\">\n            ${iBox('Rating', `<span style=\"color:#10b981;font-size:1.4em\">${fmt(p.final_rating)}</span>`)}\n            ${iBox('Two-Way', p.two_way==='Y'?'Yes':'No')}\n            ${iBox('GP', p.gp??'-')}\n            ${iBox('MIN/G', fmt(p.min))}\n            ${iBox('PER', fmt(p.per))}\n            ${iBox('TS%', fmtP(p.ts_pct))}\n            ${iBox('Win Shares', fmt(p.ws,2))}\n            ${iBox('USG%', p.usg_pct!=null?Number(p.usg_pct).toFixed(1)+'%':'-')}\n        </div>\n\n        <div class=\"stats-section\">\n            <h3>Per-Game Stats</h3>\n            <div class=\"stats-grid\">\n                ${sBox('Points', fmt(p.pts))}\n                ${sBox('Rebounds', fmt(p.reb))}\n                ${sBox('Assists', fmt(p.ast))}\n                ${sBox('Steals', fmt(p.stl))}\n                ${sBox('Blocks', fmt(p.blk))}\n                ${sBox('Turnovers', fmt(p.tov))}\n                ${sBox('Off Reb', fmt(p.off_reb))}\n                ${sBox('Def Reb', fmt(p.def_reb))}\n                ${sBox('Fouls', fmt(p.pf))}\n                ${sBox('FGM–FGA', `${fmt(p.fgm)}–${fmt(p.fga)}`)}\n                ${sBox('FG%', fmtP(p.fg_pct))}\n                ${sBox('3PM–3PA', `${fmt(p.fg3m)}–${fmt(p.fg3a)}`)}\n                ${sBox('3P%', fmtP(p.fg3_pct))}\n                ${sBox('FTM–FTA', `${fmt(p.ftm)}–${fmt(p.fta)}`)}\n                ${sBox('FT%', fmtP(p.ft_pct))}\n            </div>\n        </div>\n\n        ${p.t_pts != null ? `\n        <div class=\"stats-section\">\n            <h3>Season Totals</h3>\n            <div class=\"stats-grid\">\n                ${sBox('Total MIN', fmt(p.t_min,0))}\n                ${