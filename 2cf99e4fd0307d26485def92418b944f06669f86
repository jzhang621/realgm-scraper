ass=\"stat-value\"${color?` style=\"color:${color}\"`:''}}>${val}</div></div>`;\n}\nfunction pctBox(label, val) {\n    const v = val != null ? Math.min(100, Math.max(0, Number(val))) : 0;\n    return `<div class=\"pct-box\">\n        <div class=\"pct-label\">${label}</div>\n        <div class=\"pct-bar-wrap\"><div class=\"pct-bar\" style=\"width:${v}%\"></div></div>\n        <div class=\"pct-value\">${val != null ? val+'th' : '-'}</div>\n    </div>`;\n}\n\nfunction closeModal() { document.getElementById('playerModal').classList.remove('show'); }\nwindow.onclick = e => { if (e.target === document.getElementById('playerModal')) closeModal(); };\n</script>\n</body>\n</html>\n",
