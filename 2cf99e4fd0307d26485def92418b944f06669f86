            "content": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>NCAA Basketball Stats</title>\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;\n            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\n            min-height: 100vh;\n            padding: 20px;\n        }\n\n        .container {\n            max-width: 1600px;\n            margin: 0 auto;\n        }\n\n        .header {\n            background: white;\n            padding: 30px;\n            border-radius: 15px;\n            box-shadow: 0 10px 30px rgba(0,0,0,0.2);\n            margin-bottom: 20px;\n            text-align: center;\n        }\n\n        .header h1 {\n            color: #333;\n            font-size: 2.5em;\n            margin-bottom: 10px;\n        }\n\n        .controls {\n            background: white;\n            padding: 20px 25px;\n            border-radius: 15px;\n            box-shadow: 0 10px 30px rgba(0,0,0,0.2);\n            margin-bottom: 15px;\n        }\n\n        .filter-group {\n            display: flex;\n            flex-wrap: wrap;\n            gap: 12px;\n            align-items: center;\n        }\n\n        .filter-group label {\n            font-size: 13px;\n            font-weight: 600;\n            color: #555;\n        }\n\n        .filter-group select,\n        .filter-group input {\n            padding: 7px 10px;\n            border: 2px solid #e0e0e0;\n            border-radius: 8px;\n            font-size: 13px;\n        }\n\n        .results-count {\n            font-size: 13px;\n            color: #888;\n            margin-left: auto;\n        }\n\n        .table-container {\n            background: white;\n            border-radius: 15px;\n            box-shadow: 0 10px 30px rgba(0,0,0,0.2);\n            overflow-x: auto;\n        }\n\n        table {\n            width: 100%;\n            border-collapse: collapse;\n            font-size: 13px;\n        }\n\n        thead {\n            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\n            color: white;\n            position: sticky;\n            top: 0;\n            z-index: 10;\n        }\n\n        th {\n            padding: 12px 10px;\n            text-align: right;\n            font-weight: 600;\n            white-space: nowrap;\n            cursor: pointer;\n            user-select: none;\n        }\n\n        th:first-child,\n        th:nth-child(2),\n        th:nth-child(3),\n        th:nth-child(4),\n        th:nth-child(5) {\n            text-align: left;\n        }\n\n        th:hover {\n            background: rgba(255,255,255,0.15);\n        }\n\n        th.sort-asc::after  { content: ' ↑'; }\n        th.sort-desc::after { content: ' ↓'; }\n\n        td {\n            padding: 9px 10px;\n            border-bottom: 1px solid #f0f0f0;\n            text-align: right;\n            white-space: nowrap;\n        }\n\n        td:first-child,\n        td:nth-child(2),\n        td:nth-child(3),\n        td:nth-child(4),\n        td:nth-child(5) {\n            text-align: left;\n        }\n\n        tr:hover {\n            background: #f8f9ff;\n        }\n\n        .player-name {\n            font-weight: 600;\n            color: #667eea;\n            cursor: pointer;\n        }\n\n        .player-name:hover {\n            text-decoration: underline;\n        }\n\n        .rating-cell {\n            font-weight: bold;\n            font-size: 1.05em;\n            color: #10b981;\n        }\n\n        .two-way-badge {\n            display: inline-block;\n            padding: 2px 6px;\n            background: linear-gradient(135deg, #f59e0b 0%, #dc2626 100%);\n            color: white;\n            border-radius: 4px;\n            font-size: 0.75em;\n            font-weight: bold;\n            margin-left: 4px;\n            vertical-align: middle;\n        }\n\n        /* Modal styles */\n        .modal {\n            display: none;\n            position: fixed;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            background: rgba(0,0,0,0.5);\n            z-index: 1000;\n            overflow-y: auto;\n        }\n\n        .modal.show {\n            display: block;\n        }\n\n        .modal-content {\n            background: white;\n            max-width: 960px;\n            margin: 40px auto;\n            border-radius: 15px;\n            padding: 30px;\n            position: relative;\n        }\n\n        .close-btn {\n            position: absolute;\n            top: 15px;\n            right: 20px;\n            font-size: 28px;\n            font-weight: bold;\n            color: #999;\n            cursor: pointer;\n            background: none;\n            border: none;\n            line-height: 1;\n        }\n\n        .close-btn:hover { color: #333; }\n\n        .player-header {\n            margin-bottom: 20px;\n            padding-bottom: 15px;\n            border-bottom: 2px solid #f0f0f0;\n        }\n\n        .player-header h2 {\n            color: #333;\n            font-size: 1.8em;\n            margin-bottom: 6px;\n        }\n\n        .player-header .meta {\n            color: #666;\n            font-size: 1em;\n        }\n\n        .player-overview {\n            display: grid;\n            grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));\n            gap: 10px;\n            margin-bottom: 25px;\n        }\n\n        .info-item {\n            padding: 12px;\n            background: #f8f9ff;\n            border-radius: 8px;\n        }\n\n        .info-label {\n            font-size: 0.78em;\n            color: #888;\n            text-transform: uppercase;\n            letter-spacing: 0.5px;\n            margin-bottom: 4px;\n        }\n\n        .info-value {\n            font-size: 1.15em;\n            font-weight: bold;\n            color: #333;\n        }\n\n        .stats-section {\n            margin-bottom: 22px;\n        }\n\n        .stats-section h3 {\n            color: #667eea;\n            margin-bottom: 10px;\n            font-size: 1.1em;\n            border-bottom: 1px solid #eee;\n            padding-bottom: 6px;\n        }\n\n        .stats-grid {\n            display: grid;\n            grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));\n            gap: 8px;\n        }\n\n        .stat-box {\n            padding: 10px 12px;\n            background: #f8f9ff;\n            border-radius: 8px;\n            border-left: 3px solid #667eea;\n        }\n\n        .stat-label {\n            font-size: 0.78em;\n            color: #888;\n            text-transform: uppercase;\n            letter-spacing: 0.4px;\n        }\n\n        .stat-value {\n            font-size: 1.2em;\n            font-weight: bold;\n            color: #333;\n            margin-top: 2px;\n        }\n\n        .percentile-grid {\n            display: grid;\n            grid-template-columns: repeat(auto-fill, minmax(110px, 1fr));\n            gap: 8px;\n        }\n\n        .pct-box {\n            padding: 8px 10px;\n            border-radius: 8px;\n            border: 1px solid #e8e8e8;\n        }\n\n        .pct-label {\n            font-size: 0.75em;\n            color: #888;\n        }\n\n        .pct-bar-wrap {\n            background: #eee;\n            border-radius: 3px;\n            height: 5px;\n            margin: 4px 0;\n        }\n\n        .pct-bar {\n            height: 5px;\n            border-radius: 3px;\n            background: linear-gradient(90deg, #667eea, #764ba2);\n        }\n\n        .pct-value {\n            font-size: 0.85em;\n            font-weight: bold;\n            color: #333;\n        }\n\n        .loading {\n            text-align: center;\n            padding: 50px;\n            font-size: 1.2em;\n            color: #666;\n        }\n\n        .realgm-link {\n            display: inline-block;\n            margin-top: 12px;\n            padding: 6px 14px;\n            background: #667eea;\n            color: white;\n            border-radius: 6px;\n            text-decoration: none;\n            font-size: 0.9em;\n        }\n\n        .realgm-link:hover {\n            background: #5a6fd4;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <div class=\"header\">\n            <h1>NCAA D1 Basketball Stats</h1>\n            <p>Player Ratings &amp; Statistics Database</p>\n        </div>\n\n        <div class=\"controls\">\n            <div class=\"filter-group\">\n                <label>Season:</label>\n                <select id=\"seasonSelect\">\n                    <option value=\"2025-26\">2025-26</option>\n                    <option value=\"2024-25\">2024-25</option>\n                    <option value=\"2023-24\">2023-24</option>\n                    <option value=\"2022-23\">2022-23</option>\n                    <option value=\"2021-22\">2021-22</option>\n                </select>\n\n                <label>Position:</label>\n                <select id=\"positionFilter\">\n                    <option value=\"\">All Positions</option>\n                </select>\n\n                <label>Team:</label>\n                <select id=\"teamFilter\">\n                    <option value=\"\">All Teams</option>\n                </select>\n\n                <label>Min Rating:</label>\n                <input type=\"number\" id=\"minRating\" placeholder=\"0\" min=\"0\" max=\"100\" style=\"width: 75px\">\n\n                <label>Two-Way:</label>\n                <select id=\"twoWayFilter\">\n                    <option value=\"\">All</option>\n                    <option value=\"Y\">Two-Way Only</option>\n                </select>\n\n                <label>Search:</label>\n                <input type=\"text\" id=\"searchBox\" placeholder=\"Player name...\" style=\"width: 180px\">\n\n                <span class=\"results-count\" id=\"resultsCount\"></span>\n            </div>\n        </div>\n\n        <div id=\"loading\" class=\"loading\">Loading data...</div>\n\n        <div class=\"table-container\" id=\"tableContainer\" style=\"display: none;\">\n            <table>\n                <thead>\n                    <tr>\n                        <th style=\"cursor:default\">#</th>\n                        <th data-col=\"full_name\" style=\"min-width:160px\">Player</th>\n                        <th data-col=\"team\" style=\"min-width:130px\">Team</th>\n                        <th data-col=\"position\">Pos</th>\n                        <th data-col=\"class_year\">Yr</th>\n                        <th data-col=\"gp\">GP</th>\n                        <th data-col=\"min\">MIN</th>\n                        <th data-col=\"pts\">PPG</th>\n                        <th data-col=\"reb\">RPG</th>\n                        <th data-col=\"ast\">APG</th>\n                        <th data-col=\"stl\">SPG</th>\n                        <th data-col=\"blk\">BPG</th>\n                        <th data-col=\"tov\">TOV</th>\n                        <th data-col=\"fg_pct\">FG%</th>\n                        <th data-col=\"fg3_pct\">3P%</th>\n                        <th data-col=\"ft_pct\">FT%</th>\n                        <th data-col=\"ts_pct\">TS%</th>\n                        <th data-col=\"per\">PER</th>\n                        <th data-col=\"usg_pct\">USG%</th>\n                        <th data-col=\"ws\">WS</th>\n                        <th data-col=\"final_rating\" class=\"sort-desc\">Rating</th>\n                    </tr>\n                </thead>\n                <tbody id=\"tableBody\"></tbody>\n            </table>\n        </div>\n    </div>\n\n    <!-- Player Detail Modal -->\n    <div id=\"playerModal\" class=\"modal\">\n        <div class=\"modal-content\">\n            <button class=\"close-btn\" onclick=\"closePlayerModal()\">&times;</button>\n            <div id=\"playerDetails\">\n                <div class=\"loading\">Loading player details...</div>\n            </div>\n        </div>\n    </div>\n\n    <script>\n        const API_BASE = 'http://localhost:8000/api';\n        let allPlayers = [];\n        let currentSeason = '2025-26';\n        let sortCol = 'final_rating';\n        let sortDir = -1; // -1 = desc\n\n        document.addEventListener('DOMContentLoaded', () => {\n            loadPlayers();\n\n            document.getElementById('seasonSelect').addEventListener('change', (e) => {\n                currentSeason = e.target.value;\n                loadPlayers();\n            });\n\n            ['positionFilter','teamFilter','minRating','twoWayFilter','searchBox'].forEach(id => {\n                document.getElementById(id).addEventListener(id === 'searchBox' || id === 'minRating' ? 'input' : 'change', filterAndDisplay);\n            });\n\n            // Column sorting\n            document.querySelectorAll('th[data-col]').forEach(th => {\n                th.addEventListener('click', () => {\n                    const col = th.dataset.col;\n                    if (sortCol === col) {\n                        sortDir *= -1;\n                    } else {\n                        sortCol = col;\n                        sortDir = -1;\n                    }\n                    document.querySelectorAll('th').forEach(t => t.classList.remove('sort-asc','sort-desc'));\n                    th.classList.add(sortDir === -1 ? 'sort-desc' : 'sort-asc');\n                    filterAndDisplay();\n                });\n            });\n        });\n\n        async function loadPlayers() {\n            try {\n                document.getElementById('loading').style.display = 'block';\n                document.getElementById('tableContainer').style.display = 'none';\n\n                const response = await fetch(`${API_BASE}/players/${currentSeason}?limit=15000`);\n                const data = await response.json();\n\n                allPlayers = data.data;\n\n                // Populate position filter\n                const positions = [...new Set(allPlayers.map(p => p.position).filter(Boolean))].sort();\n                const posSelect = document.getElementById('positionFilter');\n                posSelect.innerHTML = '<option value=\"\">All Positions</option>';\n                positions.forEach(pos => posSelect.innerHTML += `<option value=\"${pos}\">${pos}</option>`);\n\n                // Populate team filter\n                const teams = [...new Set(allPlayers.map(p => p.team).filter(Boolean))].sort();\n                const teamSelect = document.getElementById('teamFilter');\n                teamSelect.innerHTML = '<option value=\"\">All Teams</option>';\n                teams.forEach(team => teamSelect.innerHTML += `<option value=\"${team}\">${team}</option>`);\n\n                filterAndDisplay();\n\n                document.getElementById('loading').style.display = 'none';\n                document.getElementById('tableContainer').style.display = 'block';\n\n            } catch (error) {\n                console.error('Error loading data:', error);\n                document.getElementById('loading').textContent = 'Error loading data. Is the API running? Check console.';\n            }\n        }\n\n        function filterAndDisplay() {\n            const position = document.getElementById('positionFilter').value;\n            const team = document.getElementById('teamFilter').value;\n            const minRating = parseFloat(document.getElementById('minRating').value) || 0;\n            const twoWay = document.getElementById('twoWayFilter').value;\n            const search = document.getElementById('searchBox').value.toLowerCase().trim();\n\n            let filtered = allPlayers.filter(p => {\n                if (position && p.position !== position) return false;\n                if (team && p.team !== team) return false;\n                if (p.final_rating < minRating) return false;\n                if (twoWay === 'Y' && p.two_way !== 'Y') return false;\n                if (search && !p.full_name.toLowerCase().includes(search)) return false;\n                return true;\n            });\n\n            // Sort\n            filtered.sort((a, b) => {\n                let av = a[sortCol], bv = b[sortCol];\n                if (av == null && bv == null) return 0;\n                if (av == null) return 1;\n                if (bv == null) return -1;\n                if (typeof av === 'string') return av.localeCompare(bv) * sortDir;\n                return (av - bv) * sortDir;\n            });\n\n            document.getElementById('resultsCount').textContent = `${filtered.length.toLocaleString()} players`;\n            displayPlayers(filtered);\n        }\n\n        function fmt(v, decimals = 1) {\n            return v != null ? Number(v).toFixed(decimals) : '-';\n        }\n\n        function fmtPct(v, decimals = 1) {\n            return v != null ? (Number(v) * 100).toFixed(decimals) + '%' : '-';\n        }\n\n        function displayPlayers(players) {\n            const tbody = document.getElementById('tableBody');\n            tbody.innerHTML = '';\n\n            const MAX_DISPLAY = 500;\n            players.slice(0, MAX_DISPLAY).forEach((p, i) => {\n                const row = document.createElement('tr');\n                row.style.cursor = 'pointer';\n                row.addEventListener('click', () => showPlayerDetail(p.player_id));\n                row.innerHTML = `\n                    <td style=\"color:#aaa;font-size:0.9em\">${i + 1}</td>\n                    <td>\n                        <span class=\"player-name\">${p.full_name}</span>\n                        ${p.two_way === 'Y' ? '<span class=\"two-way-badge\">2-WAY</span>' : ''}\n                    </td>\n                    <td>${p.team || '-'}</td>\n                    <td>${p.position || '-'}</td>\n                    <td style=\"color:#888\">${p.class_year || '-'}</td>\n                    <td>${p.gp ?? '-'}</td>\n                    <td>${fmt(p.min)}</td>\n                    <td>${fmt(p.pts)}</td>\n                    <td>${fmt(p.reb)}</td>\n                    <td>${fmt(p.ast)}</td>\n                    <td>${fmt(p.stl)}</td>\n                    <td>${fmt(p.blk)}</td>\n                    <td>${fmt(p.tov)}</td>\n                    <td>${fmtPct(p.fg_pct)}</td>\n                    <td>${fmtPct(p.fg3_pct)}</td>\n                    <td>${fmtPct(p.ft_pct)}</td>\n                    <td>${fmtPct(p.ts_pct)}</td>\n                    <td>${fmt(p.per)}</td>\n                    <td>${p.usg_pct != null ? Number(p.usg_pct).toFixed(1) : '-'}</td>\n                    <td>${fmt(p.ws, 2)}</td>\n                    <td class=\"rating-cell\">${fmt(p.final_rating, 1)}</td>\n                `;\n                tbody.appendChild(row);\n            });\n\n            if (players.length > MAX_DISPLAY) {\n                const row = document.createElement('tr');\n                row.innerHTML = `<td colspan=\"21\" style=\"text-align:center;color:#888;padding:12px\">\n                    Showing top ${MAX_DISPLAY} of ${players.length.toLocaleString()} — use filters to narrow results\n                </td>`;\n                tbody.appendChild(row);\n            }\n        }\n\n        function showPlayerDetail(playerId) {\n            const player = allPlayers.find(p => p.player_id == playerId);\n            if (!player) return;\n\n            const modal = document.getElementById('playerModal');\n            const details = document.getElementById('playerDetails');\n            modal.classList.add('show');\n\n            const realgmUrl = `https://basketball.realgm.com/player/x/Summary/${player.player_id}`;\n\n            details.innerHTML = `\n                <div class=\"player-header\">\n                    <h2>${player.full_name}</h2>\n                    <div class=\"meta\">\n                        ${player.team || '-'} &nbsp;|&nbsp; ${player.position || '-'} &nbsp;|&nbsp;\n                        ${player.class_year || '-'} &nbsp;|&nbsp;\n                        ${player.height || '-'} &nbsp;|&nbsp; ${player.weight ? player.weight + ' lbs' : '-'}\n                        ${player.hometown ? ' &nbsp;|&nbsp; ' + player.hometown : ''}\n                    </div>\n                    <a class=\"realgm-link\" href=\"${realgmUrl}\" target=\"_blank\">View on RealGM</a>\n                </div>\n\n                <div class=\"player-overview\">\n                    <div class=\"info-item\">\n                        <div class=\"info-label\">Rating</div>\n                        <div class=\"info-value\" style=\"color:#10b981;font-size:1.6em\">${fmt(player.final_rating, 1)}</div>\n                    </div>\n                    <div class=\"info-item\">\n                        <div class=\"info-label\">Two-Way</div>\n                        <div class=\"info-value\">${player.two_way === 'Y' ? 'Yes' : 'No'}</div>\n                    </div>\n                    <div class=\"info-item\">\n                        <div class=\"info-label\">Games Played</div>\n                        <div class=\"info-value\">${player.gp ?? '-'} <span style=\"color:#aaa;font-size:0.8em\">/ ${player.wins != null ? (player.wins + (player.losses ?? 0)) : '-'}</span></div>\n                    </div>\n                    <div class=\"info-item\">\n                        <div class=\"info-label\">Minutes</div>\n                        <div class=\"info-value\">${fmt(player.min)}</div>\n                    </div>\n                    <div class=\"info-item\">\n                        <div class=\"info-label\">Win Shares</div>\n                        <div class=\"info-value\">${fmt(player.ws, 2)}</div>\n                    </div>\n                    <div class=\"info-item\">\n                        <div class=\"info-label\">PER</div>\n                        <div class=\"info-value\">${fmt(player.per)}</div>\n                    </div>\n                    <div class=\"info-item\">\n                        <div class=\"info-label\">TS%</div>\n                        <div class=\"info-value\">${fmtPct(player.ts_pct)}</div>\n                    </div>\n                    <div class=\"info-item\">\n                        <div class=\"info-label\">Usage%</div>\n                        <div class=\"info-value\">${player.usg_pct != null ? Number(player.usg_pct).toFixed(1) + '%' : '-'}</div>\n                    </div>\n                </div>\n\n                <div class=\"stats-section\">\n                    <h3>Per-Game Stats</h3>\n                    <div class=\"stats-grid\">\n                        ${statBox('Points', fmt(player.pts))}\n                        ${statBox('Rebounds', fmt(player.reb))}\n                        ${statBox('Assists', fmt(player.ast))}\n                        ${statBox('Steals', fmt(player.stl))}\n                        ${statBox('Blocks', fmt(player.blk))}\n                        ${statBox('Turnovers', fmt(player.tov))}\n                        ${statBox('Off Reb', fmt(player.off_reb))}\n                        ${statBox('Def Reb', fmt(player.def_reb))}\n                        ${statBox('Fouls', fmt(player.pf))}\n                        ${statBox('FGM', fmt(player.fgm))}\n                        ${statBox('FGA', fmt(player.fga))}\n                        ${statBox('FG%', fmtPct(player.fg_pct))}\n                        ${statBox('3PM', fmt(player.fg3m))}\n                        ${statBox('3PA', fmt(player.fg3a))}\n                        ${statBox('3P%', fmtPct(player.fg3_pct))}\n                        ${statBox('FTM', fmt(player.ftm))}\n                        ${statBox('FTA', fmt(player.fta))}\n                        ${statBox('FT%', fmtPct(player.ft_pct))}\n                    </div>\n                </div>\n\n                <div class=\"stats-section\">\n                    <h3>Advanced Stats</h3>\n                    <div class=\"stats-grid\">\n                        ${statBox('PER', fmt(player.per))}\n                        ${statBox('TS%', fmtPct(player.ts_pct))}\n                        ${statBox('eFG%', fmtPct(player.efg_pct))}\n                        ${statBox('Usage%', player.usg_pct != null ? Number(player.usg_pct).toFixed(1) + '%' : '-')}\n                        ${statBox('ORtg', fmt(player.ortg))}\n                        ${statBox('DRtg', fmt(player.drtg))}\n                        ${statBox('OReb%', player.orb_pct != null ? Number(player.orb_pct).toFixed(1) + '%' : '-')}\n                        ${statBox('DReb%', player.drb_pct != null ? Number(player.drb_pct).toFixed(1) + '%' : '-')}\n                        ${statBox('Ast%', player.ast_pct != null ? Number(player.ast_pct).toFixed(1) + '%' : '-')}\n                        ${statBox('Tov%', player.tov_pct != null ? Number(player.tov_pct).toFixed(1) + '%' : '-')}\n                        ${statBox('Stl%', player.stl_pct != null ? Number(player.stl_pct).toFixed(1) + '%' : '-')}\n                        ${statBox('Blk%', player.blk_pct != null ? Number(player.blk_pct).toFixed(1) + '%' : '-')}\n                        ${statBox('PPR', fmt(player.ppr))}\n                        ${statBox('PPS', fmt(player.pps))}\n                    </div>\n                </div>\n\n                <div class=\"stats-section\">\n                    <h3>Misc Stats</h3>\n                    <div class=\"stats-grid\">\n                        ${statBox('Double-Doubles', player.dbl_dbl ?? '-')}\n                        ${statBox('Triple-Doubles', player.tpl_dbl ?? '-')}\n                        ${statBox('Ast/TO', fmt(player.ast_to_ratio))}\n                        ${statBox('Stl/TO', fmt(player.stl_to_ratio))}\n                        ${statBox('Win Shares', fmt(player.ws, 2))}\n                        ${statBox('OWS', fmt(player.ows, 2))}\n                        ${statBox('DWS', fmt(player.dws, 2))}\n                        ${statBox('Win%', player.win_pct != null ? (Number(player.win_pct)*100).toFixed(1) + '%' : '-')}\n                    </div>\n                </div>\n\n                <div class=\"stats-section\">\n                    <h3>Rating Breakdown</h3>\n                    <div class=\"percentile-grid\">\n                        ${pctBox('Points', player.pts_per)}\n                        ${pctBox('Rebounds', player.reb_per)}\n                        ${pctBox('Assists', player.ast_per)}\n                        ${pctBox('Steals', player.stl_per)}\n                        ${pctBox('Blocks', player.blk_per)}\n                        ${pctBox('Minutes', player.min_per)}\n                        ${pctBox('FG Made', player.fgm_per)}\n                        ${pctBox('FG%', player.fgpct_per)}\n                        ${pctBox('3PM', player.pm3_per)}\n                        ${pctBox('3P%', player.p3pct_per)}\n                        ${pctBox('FT%', player.ftpct_per)}\n                    </div>\n                    <div class=\"stats-grid\" style=\"margin-top:10px\">\n                        ${statBox('Base Rating', fmt(player.base_rating))}\n                        ${statBox('Game Adj', fmt(player.game_adj))}\n                        ${statBox('Min Boost', fmt(player.min_boost))}\n                        ${statBox('3P Boost', fmt(player.three_boost))}\n                        ${statBox('FG Boost', fmt(player.fg_boost))}\n                        ${statBox('Ast Boost', fmt(player.ast_boost))}\n                        ${statBox('Blk Boost', fmt(player.blk_boost))}\n                        ${statBox('DD Boost', fmt(player.double_double_boost))}\n                        ${statBox('TD Boost', fmt(player.triple_double_boost))}\n                        ${statBox('FT Boost', fmt(player.free_throw_boost))}\n                        ${statBox('Final Rating', fmt(player.final_rating), '#10b