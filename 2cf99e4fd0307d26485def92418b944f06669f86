e FileNotFoundError(f\"404 Not Found: {url}\")\n104\t\n105\t                elif resp.status_code == 403:\n106\t                    logger.warning(f\"403 Forbidden: {url} — refreshing scraper session\")\n107\t                    self._scraper = self._new_scraper()\n108\t                    if attempt == config.MAX_RETRIES:\n109\t                        raise PermissionError(f\"403 Forbidden after {attempt} attempts: {url}\")\n110\t\n111\t                elif resp.status_code in (429, 500, 502, 503, 504):\n112\t                    logger.warning(f\"HTTP {resp.status_code}: {url} — backing off {sleep}s\")\n113\t\n114\t                else:\n115\t                    raise RuntimeError(f\"Unexpected HTTP {resp.status_code}: {url}\")\n116\t\n117\t            except (cloudscraper.exceptions.CloudflareChallengeError,\n118\t                    cloudscraper.exceptions.CloudflareIUAMError) as e:\n119\t                logger.warning(f\"Cloudflare challenge on {url}: {e} — backing off {sleep}s\")\n120\t                last_error = e\n121\t\n122\t            except Exception as e:\n123\t                # Catch requests.ConnectionError, Timeout, etc.\n124\t                cls = type(e).__name__\n125\t                if cls in (\"ConnectionError\", \"Timeout\", \"ReadTimeout\"):\n126\t                    logger.warning(f\"Network error on {url}: {e} — backing off {sleep}s\")\n127\t                    last_error = e\n128\t                else:\n129\t                    raise  # re-raise unexpected errors immediately\n130\t\n131\t            # Exponential backoff before retry\n132\t            if attempt < config.MAX_RETRIES:\n133\t                time.sleep(sleep)\n134\t                sleep *= 2\n135\t\n136\t        raise RuntimeError(f\"Failed to fetch {url} after {config.MAX_RETRIES} attempts. Last error: {last_error}\")\n137\t\n138\t\n139\t# Module-level singleton\n140\t_fetcher = None\n141\t\n142\t\n143\tdef get(url: str, use_cache: bool = True) -> str:\n144\t    global _fetch